---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import {
  getCanonicalOgImagePathFromSlug,
  getCanonicalPathFromSlug,
} from "@/domain/content/path";
import { slugifyStr } from "@/utils/slugify";
import { getReadingTime } from "@/utils/readingTime";
import { toArticleView } from "@/utils/articleView";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import RelatedPosts from "@/components/RelatedPosts.astro";
import ArticleJsonLd from "@/components/ArticleJsonLd.astro";
import ContextLinkSection from "@/components/ContextLinkSection.astro";
import ArticleDecisionIntro from "@/components/ArticleDecisionIntro.astro";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { getSueldoArticleSections } from "@/config/sueldoClusterLinks";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;
const article = toArticleView(post);
const readingTime = getReadingTime(post.body ?? "");

const {
  title = article.title,
  author = article.author,
  description = article.description,
  ogImage: initOgImage,
  canonicalURL = article.canonical,
  pubDatetime = article.pubDate,
  modDatetime = article.updatedDate,
  timezone,
  tags = article.tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = getCanonicalOgImagePathFromSlug(article.slug);
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.site ?? Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL: new URL(
    canonicalURL ?? getCanonicalPathFromSlug(article.slug),
    Astro.site ?? Astro.url.origin
  ).href,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(entry => {
  const relatedArticle = toArticleView(entry);
  return {
    slug: relatedArticle.slug,
    title: relatedArticle.title,
  };
});

const currentPostIndex = allPosts.findIndex(a => a.slug === article.slug);
const contextualSections = getSueldoArticleSections(article.slug);
const articleLead = post.data.articleLead;

const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  {
    article.unlisted && (
      <meta name="robots" content="noindex,follow" slot="head" />
    )
  }
  <ArticleJsonLd
    {post}
    canonicalUrl={layoutProps.canonicalURL ?? ""}
    ogImageUrl={ogImage}
  />
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body={!article.unlisted || undefined}
    data-analytics-page-type="article"
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
      style="font-family: var(--font-display);"
    >
      {title}
    </h1>

    <div class="my-2 flex items-center gap-2">
      <Datetime
        {pubDatetime}
        {modDatetime}
        {timezone}
        readingTime={readingTime}
        size="lg"
      />
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>

    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
      data-analytics-article={article.slug}
      data-analytics-article-title={title}
    >
      {
        articleLead && (
          <ArticleDecisionIntro
            lead={articleLead}
            reviewedDate={article.updatedDate ?? article.pubDate}
          />
        )
      }
      <Content />
    </article>

    {contextualSections.map(section => <ContextLinkSection {...section} />)}

    <!-- Author Card -->
    <aside
      class="mt-10 flex flex-col gap-4 rounded-xl border border-border bg-surface-muted p-5 sm:flex-row sm:items-start"
      aria-label="Información del autor"
    >
      <a href={getPath("/autor/")} class="shrink-0">
        <img
          src={SITE.authorImage}
          alt={`Foto de ${SITE.authorFullName}`}
          width="452"
          height="461"
          class="h-12 w-12 rounded-full border border-accent/30 object-cover object-center"
          loading="lazy"
          decoding="async"
        />
      </a>
      <div class="flex-1">
        <p class="text-xs font-semibold tracking-widest text-accent uppercase">
          Autor
        </p>
        <p class="mt-0.5 font-semibold text-foreground">
          <a
            href={getPath("/autor/")}
            class="underline-offset-4 transition-colors hover:text-accent hover:underline"
          >
            {SITE.authorFullName}
          </a>
        </p>
        <p class="mt-1 text-sm leading-relaxed text-secondary">
          Abogado, analista de datos y desarrollador especializado en educación
          financiera práctica. Analiza normativa financiera chilena y desarrolla
          herramientas basadas en evidencia.
        </p>
        <div
          class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted"
        >
          <a
            href={SITE.authorLinkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-accent"
          >
            LinkedIn ↗
          </a>
          <a
            href={getPath("/autor/")}
            class="transition-colors hover:text-accent"
          >
            Sobre el autor →
          </a>
          {
            article.updatedDate && (
              <span class="text-muted">
                Revisado el{" "}
                {new Date(article.updatedDate).toLocaleDateString("es-CL", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            )
          }
        </div>
      </div>
    </aside>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />

    <ShareLinks />

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getCanonicalPathFromSlug(prevPost.slug)}
            class="flex w-full gap-1 hover:opacity-75"
            data-analytics-cta="article-nav"
            data-analytics-label={prevPost.title}
            data-analytics-location="article_previous"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>Artículo anterior</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getCanonicalPathFromSlug(nextPost.slug)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
            data-analytics-cta="article-nav"
            data-analytics-label={nextPost.title}
            data-analytics-location="article_next"
          >
            <div>
              <span>Artículo siguiente</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>

    <RelatedPosts
      currentSlug={article.slug}
      currentTags={tags}
      allPosts={posts}
    />
  </main>

  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copiar";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-surface-muted border border-surface-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copiado";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
