---
import { getPath } from "@/utils/getPath";

type SourceLink = {
  label: string;
  href: string;
};

type ArticleLead = {
  answer: string;
  calculatorHref?: string;
  calculatorLabel?: string;
  nextStepHref?: string;
  nextStepLabel?: string;
  validAsOf?: Date;
  officialSources?: SourceLink[];
  covers?: string[];
  limits?: string[];
};

type Props = {
  lead: ArticleLead;
  reviewedDate?: Date | null;
};

const { lead, reviewedDate } = Astro.props;

const validAsOf = lead.validAsOf ?? reviewedDate ?? null;
const hasSources = (lead.officialSources?.length ?? 0) > 0;
const hasCovers = (lead.covers?.length ?? 0) > 0;
const hasLimits = (lead.limits?.length ?? 0) > 0;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("es-CL", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
---

<section
  class="mt-8 rounded-2xl border border-accent/20 bg-surface-muted/40 p-5 sm:p-6"
  aria-label="Resumen práctico del artículo"
>
  <div class="grid gap-6 lg:grid-cols-[minmax(0,1.35fr)_minmax(280px,0.95fr)]">
    <div>
      <p class="text-xs font-semibold tracking-[0.18em] text-accent uppercase">
        Respuesta rápida
      </p>
      <p class="mt-3 text-base leading-relaxed text-foreground sm:text-lg">
        {lead.answer}
      </p>

      {
        (lead.calculatorHref || lead.nextStepHref) && (
          <div class="mt-5 flex flex-wrap gap-3">
            {lead.calculatorHref && lead.calculatorLabel && (
              <a
                href={getPath(lead.calculatorHref)}
                class="inline-flex items-center rounded-full bg-accent px-4 py-2 text-sm font-semibold text-background transition-opacity hover:opacity-90"
                data-analytics-cta="article-decision-intro"
                data-analytics-location="intro_primary"
                data-analytics-label={lead.calculatorLabel}
              >
                {lead.calculatorLabel}
              </a>
            )}
            {lead.nextStepHref && lead.nextStepLabel && (
              <a
                href={getPath(lead.nextStepHref)}
                class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm font-semibold text-foreground transition-colors hover:border-accent hover:text-accent"
                data-analytics-cta="article-decision-intro"
                data-analytics-location="intro_secondary"
                data-analytics-label={lead.nextStepLabel}
              >
                {lead.nextStepLabel}
              </a>
            )}
          </div>
        )
      }
    </div>

    <aside class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
      <div class="rounded-xl border border-border bg-background p-4">
        <p class="text-xs font-semibold tracking-[0.14em] text-muted uppercase">
          Vigencia
        </p>
        <p class="mt-2 text-sm leading-relaxed text-foreground">
          {
            validAsOf
              ? `Fecha de corte ${formatDate(validAsOf)}.`
              : "Revisa la fecha de actualización del artículo antes de tomar decisiones."
          }
        </p>
      </div>
      <div class="rounded-xl border border-border bg-background p-4">
        <p class="text-xs font-semibold tracking-[0.14em] text-muted uppercase">
          Uso
        </p>
        <p class="mt-2 text-sm leading-relaxed text-foreground">
          Contenido educativo orientado a decidir el siguiente paso, no a
          reemplazar revisión profesional.
        </p>
      </div>
      <div class="rounded-xl border border-border bg-background p-4">
        <p class="text-xs font-semibold tracking-[0.14em] text-muted uppercase">
          Fuentes
        </p>
        {
          hasSources ? (
            <ul class="mt-2 space-y-1 text-sm leading-relaxed">
              {lead.officialSources?.map(source => (
                <li>
                  <a
                    href={source.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-foreground underline decoration-border underline-offset-4 transition-colors hover:text-accent"
                  >
                    {source.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-2 text-sm leading-relaxed text-foreground">
              Verifica el dato sensible en la fuente oficial citada dentro del
              artículo.
            </p>
          )
        }
      </div>
    </aside>
  </div>

  {
    (hasCovers || hasLimits) && (
      <div class="mt-6 grid gap-4 border-t border-border pt-5 sm:grid-cols-2">
        {hasCovers && (
          <div>
            <p class="text-xs font-semibold tracking-[0.14em] text-muted uppercase">
              Qué cubre
            </p>
            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-foreground">
              {lead.covers?.map(item => (
                <li>• {item}</li>
              ))}
            </ul>
          </div>
        )}
        {hasLimits && (
          <div>
            <p class="text-xs font-semibold tracking-[0.14em] text-muted uppercase">
              Qué no cubre
            </p>
            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-foreground">
              {lead.limits?.map(item => (
                <li>• {item}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )
  }
</section>
