---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import generalSans600 from "@/assets/fonts/general-sans-600.woff2";
import LinkButton from "./LinkButton.astro";
import Dropdown from "./Dropdown.astro";
import type { DropdownItem } from "./Dropdown.astro";
import { SITE } from "@/config";
import { getPath } from "@/utils/getPath";

const generalSans600Src = `url("${generalSans600}") format("woff2")`;

const guiasDropdown: DropdownItem[] = [
  {
    href: getPath("/guias/ahorro-e-inversion/"),
    label: "Ahorro e Inversión",
  },
  {
    href: getPath("/guias/deuda-credito/"),
    label: "Deuda y Crédito",
  },
  {
    href: getPath("/guias/empleo-ingresos/"),
    label: "Empleo e Ingresos",
  },
  {
    href: getPath("/guias/impuestos-personas/"),
    label: "Impuestos",
  },
  {
    href: getPath("/guias/pensiones-afp/"),
    label: "Pensiones y AFP",
  },
  {
    href: getPath("/guias/seguridad-financiera/"),
    label: "Seguridad Financiera",
  },
];

const { pathname } = Astro.url;
const basePath = getPath("/").replace(/\/$/, "");
const normalizedPathname =
  basePath && pathname.startsWith(basePath)
    ? pathname.slice(basePath.length) || "/"
    : pathname;

// Remove trailing slash from normalized pathname if exists
const currentPath =
  normalizedPathname.endsWith("/") && normalizedPathname !== "/"
    ? normalizedPathname.slice(0, -1)
    : normalizedPathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Saltar al contenido
</a>

<header
  class="relative z-50 app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href={getPath("/")}
      class="brand-mark absolute py-1 whitespace-nowrap sm:static sm:my-auto sm:me-8"
    >
      {SITE.title}
    </a>
    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 flex w-full flex-col gap-2",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:flex-row sm:items-center sm:gap-x-5 sm:gap-y-0",
        ]}
      >
        <li class="col-span-2">
          <Dropdown
            id="guias-dropdown"
            label="Guías"
            items={guiasDropdown.map(i => ({
              ...i,
              isActive: isActive(i.href),
            }))}
            isActive={isActive("/guias")}
          />
        </li>
        <!-- La sección Actualidad está omitida por ser una sección futura sin contenido de noticias -->
        <li class="col-span-2">
          <a
            href={getPath("/calculadoras/")}
            class:list={[
              "header-nav-item block px-4 py-3 text-center sm:px-2 sm:py-1",
              { "active-nav text-foreground": isActive("/calculadoras") },
            ]}
          >
            Calculadoras
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={getPath("/leyes/")}
            class:list={[
              "header-nav-item block px-4 py-3 text-center sm:px-2 sm:py-1",
              { "active-nav text-foreground": isActive("/leyes") },
            ]}
          >
            Marco Legal
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={getPath("/about/")}
            class:list={[
              "header-nav-item block px-4 py-3 text-center sm:px-2 sm:py-1",
              { "active-nav text-foreground": isActive("/about") },
            ]}
          >
            Nosotros
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href={getPath("/archives/")}
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                  },
                ]}
                title="Archivo"
                aria-label="archivo"
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only">Archivo</span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-1 flex items-center justify-center">
          <LinkButton
            href={getPath("/search/")}
            class:list={[
              "focus-outline flex p-3 sm:p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Buscar"
            aria-label="buscar"
          >
            <IconSearch />
            <span class="sr-only">Buscar</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 p-4 sm:size-8 hover:[&>svg]:stroke-accent"
                title="Cambiar modo claro/oscuro"
                aria-label="Cambiar tema"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<style is:global define:vars={{ generalSans600Src }}>
  @font-face {
    font-family: "General Sans";
    font-style: normal;
    font-weight: 600;
    font-display: swap;
    src: var(--generalSans600Src);
  }

  .brand-mark {
    font-family: "General Sans", var(--font-body);
    font-size: clamp(1.45rem, 1.28rem + 0.7vw, 1.8rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    text-decoration: none;
    transition: opacity 150ms ease;
  }

  .brand-mark:hover,
  .brand-mark:focus-visible {
    opacity: 0.9;
  }

  .header-nav-item {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 150ms ease;
  }

  .header-nav-item:hover,
  .header-nav-item:focus-visible {
    color: var(--text-primary);
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute(
        "aria-label",
        openMenu ? "Cerrar menú" : "Abrir menú"
      );

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
