---
export interface DropdownItem {
  href: string;
  label: string;
  icon?: string;
  isActive?: boolean;
}

export interface Props {
  label: string;
  items: DropdownItem[];
  id?: string;
  isActive?: boolean;
}

const { label, items, id = "dropdown", isActive = false } = Astro.props;
---

<div class="relative group dropdown-container" id={`${id}-container`}>
  <button
    id={`${id}-button`}
    aria-expanded="false"
    aria-controls={`${id}-menu`}
    class:list={[
      "flex w-full items-center justify-between gap-1 px-4 py-3 font-medium transition-colors hover:text-accent sm:w-auto sm:justify-start sm:px-2 sm:py-1",
      { "text-accent": isActive }
    ]}
  >
    {label}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="origin-center transition-transform duration-200"
      id={`${id}-chevron`}
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </button>

  <div
    id={`${id}-menu`}
    role="menu"
    class="dropdown-menu hidden w-full origin-top flex-col overflow-hidden sm:absolute sm:top-full sm:-left-4 sm:w-64 sm:rounded-xl sm:border sm:border-border sm:bg-background sm:p-2 sm:shadow-lg sm:backdrop-blur-xl"
  >
    {items.map(item => (
      <a
        href={item.href}
        role="menuitem"
        class:list={[
          "block rounded-lg px-4 py-2.5 sm:px-3 sm:py-2",
          "text-sm font-medium transition-colors hover:bg-accent/10 hover:text-accent focus:bg-accent/10 focus:text-accent focus:outline-none",
          "pl-8 sm:pl-3",
          { "bg-accent/5 text-accent": item.isActive }
        ]}
      >
        <div class="flex items-center gap-2">
          {item.icon && <span class="text-base leading-none" aria-hidden="true">{item.icon}</span>}
          <span>{item.label}</span>
        </div>
      </a>
    ))}
  </div>
</div>

<script>
  function setupDropdowns() {
    const containers = document.querySelectorAll(".dropdown-container");

    containers.forEach(container => {
      const button = container.querySelector("button");
      const menu = container.querySelector(".dropdown-menu");
      const chevron = container.querySelector("svg");

      if (!button || !menu || !chevron) return;

      const toggleMenu = (force?: boolean) => {
        const isExpanded = button.getAttribute("aria-expanded") === "true";
        const willExpand = force !== undefined ? force : !isExpanded;

        button.setAttribute("aria-expanded", willExpand ? "true" : "false");
        
        if (willExpand) {
          menu.classList.remove("hidden");
          menu.classList.add("flex");
          chevron.classList.add("rotate-180");
        } else {
          menu.classList.add("hidden");
          menu.classList.remove("flex");
          chevron.classList.remove("rotate-180");
        }
      };

      // Click on button toggles menu
      button.addEventListener("click", e => {
        e.preventDefault();
        e.stopPropagation();
        toggleMenu();
      });

      // Keyboard navigation (Escape to close)
      container.addEventListener("keydown", (e: Event) => {
        const kbEvent = e as KeyboardEvent;
        if (kbEvent.key === "Escape") {
          toggleMenu(false);
          button.focus();
        }
      });
    });

    // Close all dropdowns when clicking outside
    document.addEventListener("click", (e) => {
      containers.forEach(container => {
        if (!container.contains(e.target as Node)) {
          const btn = container.querySelector("button");
          const menu = container.querySelector(".dropdown-menu");
          const chev = container.querySelector("svg");
          if (btn && btn.getAttribute("aria-expanded") === "true") {
            btn.setAttribute("aria-expanded", "false");
            menu?.classList.add("hidden");
            menu?.classList.remove("flex");
            chev?.classList.remove("rotate-180");
          }
        }
      });
    });
  }

  // Setup on first load and view transitions
  setupDropdowns();
  document.addEventListener("astro:after-swap", setupDropdowns);
</script>
