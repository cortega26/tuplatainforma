---
import { getPath } from "@/utils/getPath";
import type { LinkSection } from "@/config/sueldoClusterLinks";

type Props = LinkSection;

const { eyebrow, title, description, items } = Astro.props as Props;
---

{
  items.length > 0 && (
    <section class="mt-10 rounded-2xl border border-border bg-surface-muted p-6">
      {eyebrow && (
        <p class="mb-2 text-xs font-semibold tracking-widest text-accent uppercase">
          {eyebrow}
        </p>
      )}
      <h2 class="text-xl font-bold">{title}</h2>
      <p class="mt-2 max-w-3xl text-sm leading-relaxed text-secondary">
        {description}
      </p>

      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {items.map(item => (
          <article class="rounded-xl border border-border bg-background p-5">
            <p class="mb-2 text-xs font-semibold tracking-wide text-accent uppercase">
              {item.kind}
            </p>
            <h3 class="text-base font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-secondary">
              {item.description}
            </p>
            <a
              href={getPath(item.href)}
              class="mt-4 inline-flex text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
            >
              {item.cta}
            </a>
          </article>
        ))}
      </div>
    </section>
  )
}
