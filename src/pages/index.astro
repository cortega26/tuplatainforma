---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Datetime from "@/components/Datetime.astro";
import LinkButton from "@/components/LinkButton.astro";
import ArticlePlaceholder from "@/components/ArticlePlaceholder.astro";
import SectionDivider from "@/components/SectionDivider.astro";
import { GUIDE_HUBS } from "@/config/clusters";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { getCanonicalPathFromSlug } from "@/domain/content/path";
import { getPath } from "@/utils/getPath";
import { toArticleView } from "@/utils/articleView";
import {
  getBalancedHomepagePosts,
  getHomepageHubRail,
  getHomepageLeadPost,
} from "@/utils/homepage";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const heroPost = getHomepageLeadPost(sortedPosts);
const heroArticle = heroPost ? toArticleView(heroPost) : null;
const { richPosts: recentRichPosts, compactPosts: recentCompactPosts } =
  getBalancedHomepagePosts(sortedPosts, {
    heroSlug: heroArticle?.slug ?? null,
    heroCluster: heroArticle?.cluster ?? null,
    richCount: 3,
    totalCount: SITE.postPerIndex,
  });
const heroHub =
  heroArticle?.cluster && heroArticle.cluster in GUIDE_HUBS
    ? GUIDE_HUBS[heroArticle.cluster as keyof typeof GUIDE_HUBS]
    : null;
const homepageHubRail = getHomepageHubRail(
  heroArticle?.cluster ?? null,
  recentRichPosts,
  5
);
const homePath = getPath("/");
const homeTitle =
  "Monedario | Calculadoras y guías para decisiones financieras en Chile";
const homeDescription =
  "Calculadoras y guías para entender sueldo líquido, AFP, impuestos, crédito, UF y presupuesto con información clara y práctica para Chile.";
const heroTitle = "Calculadoras y guías sobre tu plata en Chile";
const heroDescription =
  "Sueldo líquido, AFP, impuestos, crédito, UF y presupuesto en lenguaje claro. Elige el tema que quieres resolver y entra directo a la guía o calculadora.";
---

<Layout
  title={homeTitle}
  description={homeDescription}
  enableClientRouter={false}
>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-analytics-page-type="home"
    class="app-layout"
  >
    <section class="border-b border-border py-8 lg:py-10">
      <div
        class="grid gap-6 lg:grid-cols-[minmax(0,1.12fr)_minmax(300px,0.78fr)] xl:grid-cols-[minmax(0,1.22fr)_minmax(320px,0.82fr)]"
      >
        <div class="space-y-6">
          <div class="max-w-3xl">
            <h1
              class="homepage-body-heading mb-3 max-w-3xl text-2xl leading-tight font-bold sm:text-4xl"
            >
              {heroTitle}
            </h1>
            <p class="mb-5 max-w-3xl text-base leading-relaxed text-secondary">
              {heroDescription}
            </p>
            <LinkButton
              href={getPath("/guias/")}
              class="text-sm font-semibold"
              data-analytics-cta="home-hero"
              data-analytics-label="Explorar guías por tema"
              data-analytics-location="home_hero"
            >
              Explorar guías por tema <IconArrowRight
                class="inline-block rtl:-rotate-180"
              />
            </LinkButton>
          </div>

          {
            heroPost &&
              heroArticle &&
              (() => {
                const heroImage = heroArticle.heroImage;

                return (
                  <article class="overflow-hidden rounded-xl border border-accent/20 bg-background">
                    <a
                      href={getCanonicalPathFromSlug(heroArticle.slug)}
                      class="group grid h-full md:grid-cols-[minmax(0,1.12fr)_minmax(240px,0.9fr)]"
                      data-analytics-cta="home-featured"
                      data-analytics-label={heroPost.data.title}
                      data-analytics-location="home_featured_story"
                    >
                      <div class="order-2 p-5 sm:p-6 md:order-1">
                        <div class="mb-3 flex flex-wrap items-center gap-3 text-sm text-secondary">
                          <span class="rounded-full bg-accent/10 px-2.5 py-1 font-semibold text-accent">
                            Abre la portada
                          </span>
                          {heroHub && (
                            <span class="font-semibold text-foreground">
                              {heroHub.nombre}
                            </span>
                          )}
                          <Datetime
                            pubDatetime={heroArticle.pubDate}
                            modDatetime={heroArticle.updatedDate}
                            timezone={heroPost.data.timezone}
                          />
                        </div>
                        <h2 class="mb-3 text-2xl leading-tight font-bold transition-colors group-hover:text-accent sm:text-[2rem]">
                          {heroPost.data.title}
                        </h2>
                        <p class="max-w-2xl text-base leading-relaxed text-secondary">
                          {heroPost.data.description}
                        </p>
                        <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-accent">
                          Leer artículo <IconArrowRight class="inline-block" />
                        </span>
                      </div>
                      <div class="order-1 overflow-hidden border-b border-border md:order-2 md:border-b-0 md:border-l">
                        {heroImage ? (
                          <img
                            src={heroImage}
                            alt={`Portada de ${heroPost.data.title}`}
                            width="1200"
                            height="675"
                            class="aspect-[16/10] w-full object-cover md:aspect-auto md:h-full"
                            loading="eager"
                            fetchpriority="high"
                          />
                        ) : (
                          <ArticlePlaceholder tag={heroPost.data.tags?.[0]} />
                        )}
                      </div>
                    </a>
                  </article>
                );
              })()
          }
        </div>

        <aside
          class="rounded-xl border border-border bg-surface-muted/35 p-5 sm:p-6"
        >
          <div class="mb-5">
            <h2 class="homepage-body-heading text-xl font-semibold">
              Explora por tema
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-secondary">
              Elige un tema para entrar directo a guías prácticas sobre sueldo,
              ahorro, impuestos, deudas y seguridad financiera.
            </p>
          </div>

          <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
            {
              homepageHubRail.map(entry => (
                <li class="rounded-lg border border-border/80 bg-background/80 p-4">
                  <a
                    href={getPath(`/guias/${entry.slug}/`)}
                    class="group block"
                    data-analytics-cta="home-clusters"
                    data-analytics-label={entry.nombre}
                    data-analytics-location={`home_cluster_${entry.slug}`}
                  >
                    <h3 class="homepage-body-heading text-lg leading-snug font-semibold transition-colors group-hover:text-accent">
                      {entry.nombre}
                    </h3>
                    <p class="mt-1 text-sm leading-relaxed text-secondary">
                      {entry.homepageResumen}
                    </p>
                    <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-accent">
                      Ir a la guía{" "}
                      <IconArrowRight class="inline-block rtl:-rotate-180" />
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </aside>
      </div>
    </section>

    <SectionDivider />

    {
      recentRichPosts.length > 0 && (
        <section class="py-5 lg:py-6">
          <div class="rounded-xl bg-surface-muted/22 px-4 py-5 sm:px-6 sm:py-6">
            <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
              <div>
                <h2 class="homepage-body-heading text-xl font-semibold tracking-wide">
                  Actualizaciones que amplían la portada
                </h2>
                <p class="mt-2 max-w-2xl text-sm leading-relaxed text-secondary">
                  Artículos recientes para descubrir dudas nuevas y revisar
                  temas distintos al destacado principal.
                </p>
              </div>
              <LinkButton
                href={getPath("/posts/")}
                class="text-sm font-semibold"
                data-analytics-cta="home-all-posts-inline"
                data-analytics-label="Ver todos los artículos"
                data-analytics-location="home_recent_heading"
              >
                Ver todos los artículos{" "}
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>
            </div>

            <ul class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
              {recentRichPosts.map(post => (
                <Card variant="h3" {...post} />
              ))}
            </ul>

            {recentCompactPosts.length > 0 && (
              <div class="mt-6 rounded-xl border border-border bg-background px-4 py-3 sm:px-5">
                <div class="flex flex-col gap-2 border-b border-border/80 py-4 sm:flex-row sm:items-center sm:justify-between">
                  <h3 class="homepage-body-heading text-lg font-semibold">
                    Más reciente
                  </h3>
                  <p class="max-w-2xl text-sm text-secondary">
                    Una lista más compacta para seguir explorando sin sumar otra
                    grilla de cajas.
                  </p>
                </div>

                <ul class="divide-y divide-border/80">
                  {recentCompactPosts.map(post => {
                    const postArticle = toArticleView(post);

                    return (
                      <li class="py-3">
                        <a
                          href={getCanonicalPathFromSlug(postArticle.slug)}
                          class="group flex items-start justify-between gap-3"
                          data-analytics-cta="home-recent"
                          data-analytics-label={post.data.title}
                          data-analytics-location="home_recent_posts"
                        >
                          <span class="homepage-body-heading text-base leading-snug font-semibold text-foreground transition-colors group-hover:text-accent">
                            {post.data.title}
                          </span>
                          <IconArrowRight class="mt-1 shrink-0 rtl:-rotate-180" />
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}
          </div>
        </section>
      )
    }

    <SectionDivider />

    <section
      class="mb-10 rounded-xl border border-accent/15 bg-accent/5 px-6 py-5"
    >
      <div
        class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <h2 class="homepage-body-heading text-lg font-semibold">
            Calculadoras para pasar del texto al número
          </h2>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-secondary">
            Usa estas herramientas para estimar montos, comparar escenarios y
            aterrizar la información de las guías a tu caso.
          </p>
        </div>
        <LinkButton
          href={getPath("/calculadoras/")}
          data-analytics-cta="home-calculators"
          data-analytics-label="Ver calculadoras"
          data-analytics-location="home_calculators"
        >
          Ver calculadoras <IconArrowRight
            class="inline-block rtl:-rotate-180"
          />
        </LinkButton>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  [data-layout="index"] .homepage-body-heading,
  [data-layout="index"] .card h3 {
    font-family: var(--font-body) !important;
  }
</style>

<script is:inline define:vars={{ homePath }}>
  sessionStorage.setItem("backUrl", homePath);
</script>
