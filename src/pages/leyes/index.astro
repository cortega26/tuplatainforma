---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

const AREA_LABELS: Record<string, { label: string; emoji: string }> = {
  "credito-y-deuda":          { label: "Crédito y Deuda",           emoji: "💳" },
  "prevision-y-trabajo":      { label: "Previsión y Trabajo",        emoji: "👷" },
  "tributaria":               { label: "Tributaria",                 emoji: "📊" },
  "bancaria-y-financiera":    { label: "Bancaria y Financiera",      emoji: "🏦" },
  "proteccion-al-consumidor": { label: "Protección al Consumidor",   emoji: "🛡️" },
  "privacidad-y-datos":       { label: "Privacidad y Datos",         emoji: "🔒" },
};

const allLaws = await getCollection("laws", ({ data }) => !data.draft);

const byArea = allLaws.reduce<Record<string, typeof allLaws>>((acc, law) => {
  (acc[law.data.area] ??= []).push(law);
  return acc;
}, {});

const AREA_ORDER = [
  "prevision-y-trabajo",
  "tributaria",
  "credito-y-deuda",
  "proteccion-al-consumidor",
  "bancaria-y-financiera",
  "privacidad-y-datos",
];

const areasOrdenadas = AREA_ORDER
  .filter(a => byArea[a]?.length)
  .map(a => ({
    key: a,
    ...AREA_LABELS[a],
    laws: byArea[a].sort((x, y) =>
      x.data.shortName.localeCompare(y.data.shortName, "es-CL")
    ),
  }));

const totalLaws = allLaws.length;
---

<Layout
  title={`Marco Legal Financiero Chile | ${SITE.title}`}
  description="Índice de leyes financieras, bancarias, tributarias y previsionales vigentes en Chile. Fichas explicativas con artículos clave y links al texto oficial en BCN."
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-16">

    <!-- HERO -->
    <section class="border-b border-border py-10">
      <p class="mb-3 text-xs font-semibold tracking-widest text-accent uppercase">
        Marco Legal
      </p>
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Normativa Financiera en Chile
      </h1>
      <p class="max-w-2xl text-base leading-relaxed text-secondary">
        Fichas explicativas de las principales leyes que regulan finanzas
        personales, crédito, pensiones, impuestos y protección al consumidor
        en Chile. Cada ficha resume los puntos clave para personas, cita los
        artículos de referencia y enlaza al texto oficial en la
        <a
          href="https://www.bcn.cl"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent underline underline-offset-4 hover:opacity-80"
        >
          Biblioteca del Congreso Nacional (BCN)
        </a>.
      </p>
      <p class="mt-3 text-sm text-muted">
        {totalLaws} leyes disponibles · actualización continua
      </p>
    </section>

    <!-- DISCLAIMER -->
    <section class="py-6">
      <div class="rounded-xl border border-accent/20 bg-accent/5 px-5 py-4 text-sm text-secondary">
        ⚠️ <strong class="text-foreground">Contenido educativo.</strong>
        Las fichas de esta sección explican la normativa vigente en términos
        accesibles, pero no constituyen asesoría legal o tributaria. Para
        situaciones concretas consulta a un profesional calificado. El texto
        oficial siempre prevalece sobre cualquier resumen.
      </div>
    </section>

    <!-- ÍNDICE POR ÁREA -->
    {
      areasOrdenadas.map(area => (
        <section class="border-b border-border py-8 last:border-b-0">
          <h2 class="mb-5 flex items-center gap-2 text-xl font-bold">
            <span aria-hidden="true">{area.emoji}</span>
            {area.label}
          </h2>
          <ul class="grid gap-4 sm:grid-cols-2">
            {area.laws.map(law => (
              <li class="rounded-xl border border-border p-5 transition-colors hover:border-accent/40">
                <p class="mb-1 text-xs font-semibold tracking-widest text-accent uppercase">
                  {law.data.numero}
                </p>
                <h3 class="mb-2 text-base font-semibold leading-snug">
                  <a
                    href={`/leyes/${law.id}/`}
                    class="hover:text-accent hover:underline underline-offset-4 transition-colors"
                  >
                    {law.data.shortName}
                  </a>
                </h3>
                <p class="mb-3 text-sm leading-relaxed text-secondary line-clamp-2">
                  {law.data.description}
                </p>
                <div class="flex items-center justify-between text-xs text-muted">
                  <a
                    href={`/leyes/${law.id}/`}
                    class="font-medium text-accent hover:underline underline-offset-4"
                  >
                    Ver ficha →
                  </a>
                  <a
                    href={law.data.bcnUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-accent transition-colors"
                  >
                    Texto oficial ↗
                  </a>
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </main>
  <Footer />
</Layout>
