---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getEconomicParameters } from "@/application/use-cases/GetEconomicParameters";
import { getPath } from "@/utils/getPath";

const { parameters: economicParameters } = await getEconomicParameters();
const apvGuidePath = getPath("/posts/que-es-el-apv/");
const formatCurrency = (value: number) =>
  "$" + Math.round(value).toLocaleString("es-CL");
const monthlyRegimeATarget = (40 * economicParameters.utm) / 12;
const annualRegimeABonusCap = 6 * economicParameters.utm;
const annualRegimeBContributionCap = 600 * economicParameters.uf;
const economicSourceLabel =
  economicParameters.source === "live"
    ? "dato en línea"
    : "fallback controlado";
---

<Layout
  title="Simulador APV Chile | Régimen A vs B"
  description="Compara de forma orientativa el beneficio tributario de APV en Régimen A, B o una combinación de ambos según tu sueldo y aporte mensual."
>
  <Header />
  <Breadcrumb />
  <main
    id="main-content"
    class="app-layout"
    data-analytics-page-type="calculator"
    data-analytics-calculator="apv"
    data-analytics-calculator-name="Simulador APV"
  >
    <section class="border-b border-border pt-8 pb-6">
      <h1 class="my-4 text-3xl font-bold sm:text-4xl">📈 Simulador APV</h1>
      <p class="max-w-xl text-secondary">
        Estima de forma orientativa cuánto podrías ganar con APV en Régimen A,
        Régimen B o una combinación de ambos según tu sueldo, tu ahorro mensual
        y eventuales depósitos directos adicionales.
      </p>
    </section>

    <section class="grid items-start gap-6 py-8 sm:grid-cols-2">
      <!-- FORMULARIO -->
      <div class="rounded-xl border border-border p-6">
        <h2 class="mb-5 text-lg font-semibold">📝 Ingresa tus datos</h2>

        <div class="mb-4">
          <label
            for="sueldo"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Sueldo bruto mensual ($)
          </label>
          <input
            type="number"
            id="sueldo"
            placeholder="Ej: 1.500.000"
            min="0"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
        </div>

        <div class="mb-4">
          <label
            for="ahorro"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Ahorro APV mensual ($)
          </label>
          <input
            type="number"
            id="ahorro"
            placeholder="Ej: 100.000"
            min="0"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
          <p class="mt-1 text-xs text-muted">
            Para recibir el bono máximo del Régimen A necesitas ahorrar al menos
            ~{formatCurrency(monthlyRegimeATarget)}/mes (≈ 40 UTM / 12).
          </p>
        </div>

        <div class="mb-4">
          <label
            for="aporte-directo-anual"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Aporte directo adicional anual ($) - opcional
          </label>
          <input
            type="number"
            id="aporte-directo-anual"
            placeholder="Ej: 1.000.000"
            min="0"
            value="0"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
          <p class="mt-1 text-xs text-muted">
            Úsalo solo si además haces depósitos directos fuera de planilla. En
            Régimen B ese beneficio suele reflejarse en Operación Renta y
            comparte el tope anual conjunto de ~{
              formatCurrency(annualRegimeBContributionCap)
            } (600 UF) con los descuentos por planilla.
          </p>
        </div>

        <div class="mb-4">
          <label class="mb-2 block text-sm font-medium text-secondary"
            >Sistema de salud</label
          >
          <div class="flex gap-2">
            <label class="flex-1 cursor-pointer">
              <input
                type="radio"
                name="salud"
                value="fonasa"
                checked
                class="peer sr-only"
              />
              <span
                class="block rounded-lg border border-border px-3 py-2 text-center text-sm font-medium transition-all peer-checked:border-accent peer-checked:text-accent"
              >
                Fonasa (7%)
              </span>
            </label>
            <label class="flex-1 cursor-pointer">
              <input
                type="radio"
                name="salud"
                value="isapre"
                class="peer sr-only"
              />
              <span
                class="block rounded-lg border border-border px-3 py-2 text-center text-sm font-medium transition-all peer-checked:border-accent peer-checked:text-accent"
              >
                Isapre (7%+)
              </span>
            </label>
          </div>
        </div>

        <div id="isapre-field" class="mb-4 hidden">
          <label
            for="isapre-adicional"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Cotización adicional Isapre (%)
          </label>
          <input
            type="number"
            id="isapre-adicional"
            placeholder="Ej: 2.5"
            min="0"
            max="20"
            step="0.1"
            value="2"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
        </div>

        <div class="mb-4">
          <label
            for="afp-tasa"
            class="mb-1 block text-sm font-medium text-secondary">AFP</label
          >
          <select
            id="afp-tasa"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          >
            <option value="10.58">Capital – 10.58%</option>
            <option value="10.65">Cuprum – 10.65%</option>
            <option value="10.77" selected>Habitat – 10.77%</option>
            <option value="10.58">Modelo – 10.58%</option>
            <option value="10.49">PlanVital – 10.49%</option>
            <option value="10.69">ProVida – 10.69%</option>
            <option value="10.46">Uno – 10.46%</option>
          </select>
        </div>

        <button
          id="calcBtn"
          class="mt-2 w-full rounded-lg bg-accent px-4 py-3 text-base font-bold text-background transition-opacity hover:opacity-90"
        >
          Comparar APV →
        </button>
        <div
          id="form-error"
          class="mt-3 hidden rounded-lg border border-red-500/30 bg-red-500/10 px-3 py-2 text-sm text-red-200"
          role="alert"
        >
        </div>
      </div>

      <!-- RESULTADO -->
      <div
        id="resultado"
        class="rounded-xl border border-border bg-background p-6"
      >
        <h2 class="mb-5 text-lg font-semibold">💡 Comparación de regímenes</h2>
        <div id="resultado-contenido" class="py-8 text-center text-muted">
          <p class="mb-3 text-4xl">📊</p>
          <p class="text-sm">Ingresa tus datos y presiona comparar.</p>
        </div>
        <div
          id="economic-parameters"
          data-utm={String(economicParameters.utm)}
          data-uf={String(economicParameters.uf)}
          class="hidden"
          aria-hidden="true"
        >
        </div>
        <p class="mt-3 text-xs text-muted">
          Fuente económica: {economicSourceLabel} ({
            economicParameters.lastUpdated
          }).
        </p>
      </div>
    </section>

    <!-- EXPLICACIÓN -->
    <section
      class="prose prose-sm max-w-none border-t border-border pt-8 pb-12 dark:prose-invert"
    >
      <h2>¿Qué es el APV y cómo funciona el beneficio?</h2>
      <p>
        El APV (Ahorro Previsional Voluntario) es un mecanismo legal para
        reducir impuestos mientras ahorras para tu pensión. Debes elegir entre
        dos regímenes:
      </p>
      <ul>
        <li>
          <strong>Régimen A:</strong> El Estado te deposita directamente un bono del
          15% de lo que ahorraste, con tope de 6 UTM anuales (~{
            formatCurrency(annualRegimeABonusCap)
          }).
        </li>
        <li>
          <strong>Régimen B:</strong> Tus aportes se descuentan de tu base imponible,
          reduciendo el impuesto que pagas cada mes. Ideal si estás en tramos altos
          de impuesto (23%+).
        </li>
        <li>
          <strong>Estrategia mixta:</strong> en algunos casos conviene usar una parte
          en A y otra en B. Eso depende de tu base imponible efectiva, de tu tramo
          marginal y de cuánto del bono A todavía puedes aprovechar.
        </li>
      </ul>
      <p>
        Si retiras antes de jubilar, en Régimen A devuelves el bono; en Régimen
        B pagas impuesto diferido más una sobretasa. El APV es un instrumento de
        largo plazo.
      </p>
      <p class="text-sm text-muted">
        ⚠️ Valores referenciales. Parámetros económicos vigentes al momento del
        build. Este simulador usa tu sueldo bruto como aproximación de base
        imponible. En Régimen B trata el tope de 50 UF mensuales para aportes
        por planilla y el tope conjunto anual de 600 UF como referencias
        normativas para estimar beneficio tributario. Para información oficial
        visita la <a href="https://www.spensiones.cl" target="_blank"
          >Superintendencia de Pensiones</a
        > y el <a href="https://www.sii.cl" target="_blank">SII</a>.
      </p>
      <p>
        Antes de decidir régimen, revisa la <a
          href={apvGuidePath}
          data-analytics-cta="calculator-guide"
          data-analytics-label="Guia completa de APV"
          data-analytics-location="calculator_explainer">guía completa de APV</a
        > para entender beneficios, límites y costos de retiro anticipado.
      </p>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { calculateApvComparison } from "@/application/use-cases/CalculateApvComparison";
  import { trackAnalyticsEvent } from "@/utils/analytics";

  function fmt(n: number): string {
    return "$" + Math.round(n).toLocaleString("es-CL");
  }

  function fmtPct(n: number): string {
    return (n * 100).toFixed(1) + "%";
  }

  function showFormError(message: string): void {
    const errorBox = document.getElementById("form-error");
    if (!errorBox) return;
    errorBox.textContent = message;
    errorBox.classList.remove("hidden");
  }

  function clearFormError(): void {
    const errorBox = document.getElementById("form-error");
    if (!errorBox) return;
    errorBox.textContent = "";
    errorBox.classList.add("hidden");
  }

  function readEconomicParameters(): { uf: number; utm: number } {
    const element = document.getElementById("economic-parameters");
    const uf = Number(element?.dataset?.uf);
    const utm = Number(element?.dataset?.utm);
    if (!Number.isFinite(uf) || uf <= 0 || !Number.isFinite(utm) || utm <= 0) {
      throw new Error("No se pudieron cargar los parámetros económicos.");
    }
    return { uf, utm };
  }

  const economicParameters = readEconomicParameters();

  document.querySelectorAll("input[name='salud']").forEach(radio => {
    radio.addEventListener("change", () => {
      const isIsapre =
        (
          document.querySelector(
            "input[name='salud']:checked"
          ) as HTMLInputElement
        )?.value === "isapre";
      document
        .getElementById("isapre-field")
        ?.classList.toggle("hidden", !isIsapre);
    });
  });

  document.getElementById("calcBtn")?.addEventListener("click", () => {
    clearFormError();

    const bruto =
      parseFloat(
        (document.getElementById("sueldo") as HTMLInputElement).value
      ) || 0;
    const ahorro =
      parseFloat(
        (document.getElementById("ahorro") as HTMLInputElement).value
      ) || 0;
    const aporteDirectoAnual =
      parseFloat(
        (document.getElementById("aporte-directo-anual") as HTMLInputElement)
          .value
      ) || 0;

    if (bruto <= 0 || ahorro + aporteDirectoAnual <= 0) {
      showFormError(
        "Ingresa tu sueldo y al menos un aporte APV: mensual por planilla o directo anual."
      );
      return;
    }

    const afpTasaPercent = parseFloat(
      (document.getElementById("afp-tasa") as HTMLSelectElement).value
    );
    const healthSystem =
      (
        document.querySelector(
          "input[name='salud']:checked"
        ) as HTMLInputElement
      )?.value === "isapre"
        ? "isapre"
        : "fonasa";
    const isapreAdicionalPercent =
      parseFloat(
        (document.getElementById("isapre-adicional") as HTMLInputElement).value
      ) || 0;

    let resultado;
    try {
      resultado = calculateApvComparison({
        grossSalary: bruto,
        monthlyApvContribution: ahorro,
        annualDirectApvContribution: aporteDirectoAnual,
        afpRatePercent: afpTasaPercent,
        healthSystem,
        isapreAdditionalPercent: isapreAdicionalPercent,
        economicParameters,
      });
    } catch (error) {
      showFormError(
        error instanceof Error
          ? error.message
          : "No se pudo calcular la comparación APV."
      );
      return;
    }

    const buildCard = (
      title: string,
      colorClass: string,
      items: Array<{ label: string; value: string }>,
      badgeLabel?: string
    ): HTMLDivElement => {
      const card = document.createElement("div");
      card.className = `mb-4 rounded-lg border p-4 ${
        badgeLabel ? "border-accent bg-accent/5" : "border-border"
      }`;

      if (badgeLabel) {
        const badge = document.createElement("p");
        badge.className =
          "mb-2 text-xs font-bold tracking-widest text-accent uppercase";
        badge.textContent = badgeLabel;
        card.appendChild(badge);
      }

      const titleElement = document.createElement("h3");
      titleElement.className = `mb-3 text-base font-bold ${colorClass}`;
      titleElement.textContent = title;
      card.appendChild(titleElement);

      for (const item of items) {
        const line = document.createElement("div");
        line.className =
          "flex justify-between border-b border-border py-1.5 text-sm last:border-0";

        const labelElement = document.createElement("span");
        labelElement.className = "text-secondary";
        labelElement.textContent = item.label;

        const valueElement = document.createElement("span");
        valueElement.className = "font-mono font-semibold";
        valueElement.textContent = item.value;

        line.append(labelElement, valueElement);
        card.appendChild(line);
      }

      return card;
    };

    const summary = document.createElement("div");
    summary.className =
      "mb-4 rounded-lg bg-foreground/5 p-3 text-sm text-secondary";
    const marginalText = document.createElement("p");
    const marginalStrong = document.createElement("strong");
    marginalStrong.textContent = "Tu tasa marginal de impuesto:";
    marginalText.append(marginalStrong, ` ${fmtPct(resultado.marginalRate)}`);
    const taxText = document.createElement("p");
    const taxStrong = document.createElement("strong");
    taxStrong.textContent = "Impuesto sin APV:";
    taxText.append(taxStrong, ` ${fmt(resultado.taxWithoutApv)}/mes`);
    const targetText = document.createElement("p");
    const targetStrong = document.createElement("strong");
    targetStrong.textContent = "Aporte mensual para agotar bono A:";
    targetText.append(
      targetStrong,
      ` ${fmt(resultado.regimeA.monthlyContributionForMaxBonus)}`
    );
    const directContributionText = document.createElement("p");
    const directContributionStrong = document.createElement("strong");
    directContributionStrong.textContent = "Aporte directo anual adicional:";
    directContributionText.append(
      directContributionStrong,
      ` ${fmt(aporteDirectoAnual)}`
    );
    summary.append(marginalText, taxText, targetText, directContributionText);

    const strategyMessage = document.createElement("div");
    strategyMessage.className =
      "mb-4 rounded-lg border border-border p-3 text-sm text-secondary";

    const strategyLabel = document.createElement("strong");
    strategyLabel.textContent = "Sugerencia orientativa:";

    const strategyCopy =
      resultado.recommendedStrategy === "A"
        ? " Tu beneficio estimado es mayor si concentras este aporte en Régimen A."
        : resultado.recommendedStrategy === "B"
          ? " Tu beneficio estimado es mayor si concentras este aporte en Régimen B."
          : ` Podría convenirte dividir el aporte: ${fmt(
              resultado.mixedStrategy.contributionToRegimeA
            )} en A y ${fmt(resultado.mixedStrategy.contributionToRegimeB)} en B.`;

    strategyMessage.append(strategyLabel, strategyCopy);

    const regimeACard = buildCard(
      "Régimen A — Bono del Estado",
      "text-blue-500",
      [
        {
          label: "Aporte anual bonificable considerado",
          value: fmt(resultado.regimeA.effectiveAnnualContribution),
        },
        { label: "Impuesto mensual", value: fmt(resultado.regimeA.monthlyTax) },
        {
          label: "Bono Estado anual (15%)",
          value: `+ ${fmt(resultado.regimeA.annualBonus)}`,
        },
        {
          label: "Beneficio mensual equivalente",
          value: fmt(resultado.regimeA.monthlyBenefit),
        },
        {
          label: "Aporte anual para bono máximo",
          value: fmt(resultado.regimeA.annualContributionForMaxBonus),
        },
      ],
      resultado.recommendedStrategy === "A"
        ? "Sugerencia orientativa"
        : undefined
    );

    const regimeBCard = buildCard(
      "Régimen B — Rebaja de impuesto",
      "text-green-500",
      [
        {
          label: "Aporte anual con beneficio considerado",
          value: fmt(resultado.regimeB.effectiveAnnualContribution),
        },
        {
          label: "Promedio mensual equivalente",
          value: fmt(resultado.regimeB.effectiveMonthlyContribution),
        },
        {
          label: "Descuento por planilla con beneficio",
          value: fmt(resultado.regimeB.effectiveAnnualPayrollContribution),
        },
        {
          label: "Depósito directo anual con beneficio",
          value: fmt(resultado.regimeB.effectiveAnnualDirectContribution),
        },
        {
          label: "Base imponible reducida (equiv. mensual)",
          value: fmt(resultado.regimeB.reducedTaxBase),
        },
        {
          label: "Impuesto con APV (equiv. mensual)",
          value: fmt(resultado.regimeB.monthlyTax),
        },
        {
          label: "Ahorro impuesto mensual equivalente",
          value: fmt(resultado.regimeB.monthlyBenefit),
        },
        {
          label: "Ahorro impuesto anual",
          value: fmt(resultado.regimeB.annualBenefit),
        },
      ],
      resultado.recommendedStrategy === "B"
        ? "Sugerencia orientativa"
        : undefined
    );

    const shouldRenderMixedCard =
      resultado.mixedStrategy.contributionToRegimeA > 0 &&
      resultado.mixedStrategy.contributionToRegimeB > 0;

    const mixedCard = shouldRenderMixedCard
      ? buildCard(
          "Estrategia mixta — Parte en A y parte en B",
          "text-accent",
          [
            {
              label: "Aporte anual a Régimen A",
              value: fmt(resultado.mixedStrategy.annualContributionToRegimeA),
            },
            {
              label: "Aporte anual a Régimen B",
              value: fmt(resultado.mixedStrategy.annualContributionToRegimeB),
            },
            {
              label: "Bono A mensual equivalente",
              value: fmt(resultado.mixedStrategy.regimeAMonthlyBenefit),
            },
            {
              label: "Ahorro tributario B mensual equivalente",
              value: fmt(resultado.mixedStrategy.regimeBMonthlyBenefit),
            },
            {
              label: "Beneficio total mensual",
              value: fmt(resultado.mixedStrategy.monthlyBenefit),
            },
          ],
          resultado.recommendedStrategy === "MIXED"
            ? "Sugerencia orientativa"
            : undefined
        )
      : null;

    const note = document.createElement("p");
    note.className = "mt-2 text-xs text-muted";
    note.textContent = `El bono del Régimen A se acredita en tu cuenta APV al año siguiente (Operación Renta). En Régimen B, los descuentos por planilla tienen tope mensual de 50 UF (~${fmt(resultado.regimeB.monthlyContributionCap)}) y los aportes con beneficio comparten además un tope anual conjunto de 600 UF (~${fmt(resultado.regimeB.annualContributionCap)}). Si incluyes depósitos directos, esta tarjeta muestra equivalentes mensuales para aproximar un beneficio que normalmente se regulariza en Operación Renta.`;

    document
      .getElementById("resultado-contenido")!
      .replaceChildren(
        summary,
        strategyMessage,
        regimeACard,
        regimeBCard,
        ...(mixedCard ? [mixedCard] : []),
        note
      );

    trackAnalyticsEvent("calculator_complete", {
      calculator_slug: "apv",
      calculator_name: "Simulador APV",
      outcome: "success",
    });
  });
</script>
