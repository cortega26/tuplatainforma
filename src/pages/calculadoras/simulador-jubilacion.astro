---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getEconomicParameters } from "@/application/use-cases/GetEconomicParameters";

const { parameters: economicParameters } = await getEconomicParameters();
const economicSourceLabel =
  economicParameters.source === "live"
    ? "dato en línea"
    : "fallback controlado";
---

<Layout
  title="Simulador de Jubilación Chile | Proyección AFP"
  description="Proyecta tu ahorro previsional y una pensión estimada según sueldo, edad y rentabilidad esperada."
>
  <Header />
  <Breadcrumb />
  <main
    id="main-content"
    class="app-layout"
    data-analytics-page-type="calculator"
    data-analytics-calculator="simulador-jubilacion"
    data-analytics-calculator-name="Simulador de Jubilacion"
  >
    <section class="border-b border-border pt-8 pb-6">
      <h1 class="my-4 text-3xl font-bold sm:text-4xl">
        🏖️ Simulador de Jubilación
      </h1>
      <p class="max-w-xl text-secondary">
        Proyecta tu saldo AFP con escenarios comparativos, tope imponible y
        lagunas previsionales visibles, sin mezclar beneficios que no van
        directo a tu cuenta individual.
      </p>
    </section>

    <section class="grid items-start gap-6 py-8 sm:grid-cols-2">
      <!-- FORMULARIO -->
      <div class="rounded-xl border border-border p-6">
        <h2 class="mb-5 text-lg font-semibold">📝 Tus datos</h2>

        <div class="mb-4">
          <label
            for="edad"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Edad actual (años)
          </label>
          <input
            type="number"
            id="edad"
            placeholder="Ej: 35"
            min="18"
            max="64"
            value="35"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
        </div>

        <div class="mb-4">
          <label
            for="edad-jubilacion"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Edad de jubilación (años)
          </label>
          <input
            type="number"
            id="edad-jubilacion"
            placeholder="Ej: 65"
            min="60"
            max="75"
            value="65"
            class="focus:invoke-none w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent"
          />
          <p class="mt-1 text-xs text-muted">
            Edad legal: 65 hombres, 60 mujeres (puede anticiparse).
          </p>
        </div>

        <div class="mb-4">
          <label
            for="sueldo"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Sueldo bruto mensual actual ($)
          </label>
          <input
            type="number"
            id="sueldo"
            placeholder="Ej: 1.200.000"
            min="0"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
        </div>

        <div class="mb-4">
          <label
            for="saldo-actual"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Saldo actual en AFP ($) — opcional
          </label>
          <input
            type="number"
            id="saldo-actual"
            placeholder="Ej: 8.000.000"
            min="0"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
          <p class="mt-1 text-xs text-muted">
            Consulta tu saldo en el sitio web de tu AFP.
          </p>
        </div>

        <div class="mb-4">
          <label
            for="rentabilidad"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Rentabilidad anual esperada (%)
          </label>
          <select
            id="rentabilidad"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          >
            <option value="3">3% — Conservadora (Fondos D/E)</option>
            <option value="5" selected>5% — Moderada (Fondo C)</option>
            <option value="7">7% — Agresiva (Fondos A/B)</option>
          </select>
          <p class="mt-1 text-xs text-muted">
            Este será tu escenario destacado. Más abajo verás también los otros
            escenarios comparativos.
          </p>
        </div>

        <div class="mb-4">
          <label
            for="lagunas"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Lagunas previsionales esperadas (% del tiempo restante)
          </label>
          <select
            id="lagunas"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          >
            <option value="0">0% — Cotización continua</option>
            <option value="10" selected>10% — Lagunas ocasionales</option>
            <option value="20">20% — Intermitencia relevante</option>
            <option value="30">30% — Alta inestabilidad laboral</option>
            <option value="40">40% — Trayectoria muy irregular</option>
          </select>
          <p class="mt-1 text-xs text-muted">
            Las lagunas reducen los meses en que proyectamos cotizaciones.
          </p>
        </div>

        <div class="mb-4">
          <label
            for="expectativa-vida"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Expectativa de vida estimada (años)
          </label>
          <input
            type="number"
            id="expectativa-vida"
            placeholder="Ej: 85"
            min="65"
            max="100"
            value="85"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
          <p class="mt-1 text-xs text-muted">
            Se usa para calcular cuántos años durará tu pensión.
          </p>
        </div>

        <button
          id="calcBtn"
          class="mt-2 w-full rounded-lg bg-accent px-4 py-3 text-base font-bold text-background transition-opacity hover:opacity-90"
        >
          Simular jubilación →
        </button>
        <div
          id="jubilacion-error"
          class="mt-3 hidden rounded-lg border border-red-500/30 bg-red-500/10 p-3 text-sm text-red-200"
          role="alert"
        >
        </div>
      </div>

      <!-- RESULTADO -->
      <div
        id="resultado"
        class="rounded-xl border border-border bg-background p-6"
      >
        <h2 class="mb-5 text-lg font-semibold">📊 Proyección</h2>
        <div id="resultado-contenido" class="py-8 text-center text-muted">
          <p class="mb-3 text-4xl">🏖️</p>
          <p class="text-sm">Ingresa tus datos y presiona simular.</p>
        </div>
        <div
          id="economic-parameters"
          data-uf={String(economicParameters.uf)}
          data-pension-monthly-taxable-cap-uf={String(
            economicParameters.previsionalTopes
              ?.pensionAndHealthMonthlyTaxableCapUf ?? 90
          )}
          class="hidden"
          aria-hidden="true"
        >
        </div>
        <p class="mt-3 text-xs text-muted">
          Fuente económica: {economicSourceLabel} ({
            economicParameters.lastUpdated
          }).
        </p>
      </div>
    </section>

    <!-- EXPLICACIÓN -->
    <section
      class="prose prose-sm max-w-none border-t border-border pt-8 pb-12 dark:prose-invert"
    >
      <h2>¿Cómo funciona la simulación?</h2>
      <p>
        La calculadora proyecta el saldo acumulado en tu AFP al momento de
        jubilarte, considerando las cotizaciones mensuales del 10% de tu sueldo
        imponible, el tope imponible vigente y el tramo del aporte del empleador
        que sí entra directo a tu cuenta individual según el calendario oficial.
      </p>
      <ul>
        <li>
          <strong>Cotización base:</strong> 10% de tu sueldo imponible con tope previsional.
        </li>
        <li>
          <strong>Aporte del empleador a tu cuenta individual:</strong> la simulación
          usa un cronograma versionado de la Superintendencia de Pensiones para la
          parte que entra directo a la cuenta AFP.
        </li>
        <li>
          <strong>Lagunas previsionales:</strong> reducen los meses con cotización
          y cambian materialmente el resultado.
        </li>
        <li>
          <strong>Pensión estimada:</strong> Se calcula dividiendo el saldo acumulado
          en los meses de vida restante desde la jubilación, sin considerar rentabilidad
          posterior (estimación conservadora).
        </li>
      </ul>
      <p class="text-sm text-muted">
        ⚠️ Esta es una simulación educativa del saldo AFP individual. No incluye
        PGU, comisiones, SIS, modalidad de pensión ni los componentes de
        seguridad social que no van directo a tu saldo. Para una proyección
        oficial consulta tu AFP o la <a
          href="https://www.spensiones.cl"
          target="_blank">Superintendencia de Pensiones</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { simulateRetirementProjection } from "@/application/use-cases/SimulateRetirementProjection";
  import { trackAnalyticsEvent } from "@/utils/analytics";

  function fmt(n: number): string {
    return "$" + Math.round(n).toLocaleString("es-CL");
  }

  function fmtM(n: number): string {
    if (n >= 1_000_000) return "$" + (n / 1_000_000).toFixed(1) + " millones";
    return fmt(n);
  }

  function showInlineError(message: string) {
    const errorBox = document.getElementById("jubilacion-error");
    if (!errorBox) return;
    errorBox.textContent = message;
    errorBox.classList.remove("hidden");
  }

  function clearInlineError() {
    const errorBox = document.getElementById("jubilacion-error");
    if (!errorBox) return;
    errorBox.textContent = "";
    errorBox.classList.add("hidden");
  }

  function readEconomicParameters(): {
    uf: number;
    pensionMonthlyTaxableCapUf: number;
  } {
    const element = document.getElementById("economic-parameters");
    const uf = Number(element?.dataset?.uf);
    const pensionMonthlyTaxableCapUf = Number(
      element?.dataset?.pensionMonthlyTaxableCapUf
    );

    if (
      !Number.isFinite(uf) ||
      uf <= 0 ||
      !Number.isFinite(pensionMonthlyTaxableCapUf) ||
      pensionMonthlyTaxableCapUf <= 0
    ) {
      throw new Error("No se pudieron cargar los parámetros previsionales.");
    }

    return { uf, pensionMonthlyTaxableCapUf };
  }

  const economicParameters = readEconomicParameters();

  document.getElementById("calcBtn")?.addEventListener("click", () => {
    clearInlineError();
    const edad =
      parseInt((document.getElementById("edad") as HTMLInputElement).value) ||
      35;
    const edadJubilacion =
      parseInt(
        (document.getElementById("edad-jubilacion") as HTMLInputElement).value
      ) || 65;
    const sueldo =
      parseFloat(
        (document.getElementById("sueldo") as HTMLInputElement).value
      ) || 0;
    const saldoInicial =
      parseFloat(
        (document.getElementById("saldo-actual") as HTMLInputElement).value
      ) || 0;
    const rentAnual =
      parseFloat(
        (document.getElementById("rentabilidad") as HTMLSelectElement).value
      ) / 100;
    const lagunasPercent =
      parseFloat(
        (document.getElementById("lagunas") as HTMLSelectElement).value
      ) || 0;
    const expectativaVida =
      parseInt(
        (document.getElementById("expectativa-vida") as HTMLInputElement).value
      ) || 85;

    if (sueldo <= 0) {
      showInlineError("Ingresa tu sueldo bruto mensual antes de simular.");
      return;
    }

    const añosRestantes = Math.max(0, edadJubilacion - edad);
    if (añosRestantes <= 0) {
      showInlineError(
        "La edad de jubilación debe ser mayor que tu edad actual."
      );
      return;
    }

    let proyeccion;
    try {
      proyeccion = simulateRetirementProjection({
        currentAge: edad,
        retirementAge: edadJubilacion,
        grossSalary: sueldo,
        currentBalance: saldoInicial,
        annualReturnPercent: rentAnual * 100,
        lifeExpectancyAge: expectativaVida,
        contributionDensityPercent: 100 - lagunasPercent,
        economicParameters: {
          uf: economicParameters.uf,
          previsionalTopes: {
            pensionAndHealthMonthlyTaxableCapUf:
              economicParameters.pensionMonthlyTaxableCapUf,
          },
        },
      });
    } catch (error) {
      showInlineError(
        error instanceof Error
          ? error.message
          : "No se pudo simular la jubilación."
      );
      return;
    }

    const buildRow = (label: string, value: string, colorClass = "") => {
      const line = document.createElement("div");
      line.className =
        "flex items-center justify-between border-b border-border py-2 text-sm last:border-0";

      const labelElement = document.createElement("span");
      labelElement.className = "text-secondary";
      labelElement.textContent = label;

      const valueElement = document.createElement("span");
      valueElement.className = `font-mono font-semibold ${colorClass}`.trim();
      valueElement.textContent = value;

      line.append(labelElement, valueElement);
      return line;
    };

    const buildScenarioCard = (
      label: string,
      annualReturnPercent: number,
      monthlyPension: number,
      projectedBalance: number,
      replacementPercent: number,
      emphasized = false
    ) => {
      const card = document.createElement("div");
      card.className = `rounded-lg border p-3 ${
        emphasized
          ? "border-accent/30 bg-accent/10"
          : "border-border bg-foreground/5"
      }`;

      const title = document.createElement("p");
      title.className =
        "text-xs font-bold tracking-widest text-muted uppercase";
      title.textContent = `${label} · ${annualReturnPercent}% real`;

      const pension = document.createElement("p");
      pension.className = "mt-2 text-lg font-bold";
      pension.textContent = fmt(monthlyPension);

      const subtitle = document.createElement("p");
      subtitle.className = "mt-1 text-xs text-secondary";
      subtitle.textContent = `${replacementPercent.toFixed(0)}% de reemplazo · saldo ${fmtM(projectedBalance)}`;

      card.append(title, pension, subtitle);
      return card;
    };

    const headline = document.createElement("div");
    headline.className =
      "mb-5 rounded-lg border border-accent/20 bg-accent/10 p-4 text-center";
    const headlineLabel = document.createElement("p");
    headlineLabel.className =
      "mb-1 text-xs font-bold tracking-widest text-accent uppercase";
    headlineLabel.textContent = "Saldo estimado al jubilar";
    const headlineValue = document.createElement("p");
    headlineValue.className = "text-4xl font-bold";
    headlineValue.textContent = fmtM(
      proyeccion.selectedScenario.projectedBalance
    );
    const headlineSub = document.createElement("p");
    headlineSub.className = "mt-1 text-sm text-muted";
    headlineSub.textContent = `En ${añosRestantes} años (a los ${edadJubilacion}) · escenario ${proyeccion.selectedScenario.label.toLowerCase()}`;
    headline.append(headlineLabel, headlineValue, headlineSub);

    const comparisonLabel = document.createElement("p");
    comparisonLabel.className =
      "mb-2 text-xs font-bold tracking-widest text-muted uppercase";
    comparisonLabel.textContent = "Escenarios comparativos";

    const comparisonGrid = document.createElement("div");
    comparisonGrid.className = "grid gap-3 sm:grid-cols-3";
    proyeccion.scenarios.forEach(scenario => {
      comparisonGrid.appendChild(
        buildScenarioCard(
          scenario.label,
          scenario.annualReturnPercent,
          scenario.estimatedMonthlyPension,
          scenario.projectedBalance,
          scenario.salaryReplacementPercent,
          scenario.id === "selected"
        )
      );
    });

    const hint = document.createElement("div");
    hint.className =
      "mt-4 rounded-lg bg-foreground/5 p-3 text-xs text-secondary";
    const hintTitle = document.createElement("strong");
    hintTitle.textContent = "¿Quieres mejorar esta proyección?";
    hint.append(
      hintTitle,
      document.createElement("br"),
      `Agregar APV mensual aumenta significativamente el saldo final. Con $100.000/mes de APV en los meses con cotización, el escenario destacado suma aprox. ${fmtM(proyeccion.selectedScenario.apvExtraProjectionAt100kMonthly)} adicionales al fondo.`
    );

    const scopeBox = document.createElement("div");
    scopeBox.className = "mt-4 rounded-lg bg-foreground/5 p-3 text-xs";
    const scopeTitle = document.createElement("p");
    scopeTitle.className =
      "mb-2 font-bold tracking-widest text-muted uppercase";
    scopeTitle.textContent = "Supuestos clave";
    const scopeList = document.createElement("ul");
    scopeList.className = "space-y-1 text-secondary";
    [
      `Meses con cotización proyectados: ${proyeccion.monthsWithContributions} de ${proyeccion.totalMonths}.`,
      `Sueldo usado para cotizar: ${fmt(proyeccion.taxableSalaryUsedClp)} (tope vigente ${fmt(proyeccion.salaryCapClp)}).`,
      `Cronograma empleador versionado: ${proyeccion.employerContributionScheduleVersion}.`,
      ...proyeccion.excludedBenefits,
    ].forEach(item => {
      const li = document.createElement("li");
      li.textContent = item;
      scopeList.appendChild(li);
    });
    const sourceLine = document.createElement("p");
    sourceLine.className = "mt-2 text-muted";
    const sourceLink = document.createElement("a");
    sourceLink.href = proyeccion.employerContributionScheduleSource.url;
    sourceLink.target = "_blank";
    sourceLink.className = "underline";
    sourceLink.textContent = "fuente oficial";
    sourceLine.append(
      "Cronograma del empleador: ",
      sourceLink,
      ` (${proyeccion.employerContributionScheduleSource.lastVerified}).`
    );
    scopeBox.append(scopeTitle, scopeList, sourceLine);

    document
      .getElementById("resultado-contenido")!
      .replaceChildren(
        headline,
        comparisonLabel,
        comparisonGrid,
        buildRow(
          "Pensión mensual estimada",
          fmt(proyeccion.selectedScenario.estimatedMonthlyPension),
          "text-accent"
        ),
        buildRow(
          "Como % de tu sueldo actual",
          `${proyeccion.selectedScenario.salaryReplacementPercent.toFixed(0)}%`
        ),
        buildRow(
          "Años de pensión (vida estimada)",
          `${proyeccion.pensionMonths / 12} años`
        ),
        buildRow(
          "Lagunas previsionales asumidas",
          `${lagunasPercent.toFixed(0)}% del tiempo restante`
        ),
        buildRow("Rentabilidad anual usada", `${rentAnual * 100}%`),
        buildRow("Saldo inicial ingresado", fmt(saldoInicial)),
        buildRow(
          "Aporte empleador directo proyectado",
          fmt(
            proyeccion.selectedScenario
              .totalEmployerContributionsToIndividualAccount
          )
        ),
        hint,
        scopeBox
      );

    trackAnalyticsEvent("calculator_complete", {
      calculator_slug: "simulador-jubilacion",
      calculator_name: "Simulador de Jubilacion",
      outcome: "success",
    });
  });
</script>
