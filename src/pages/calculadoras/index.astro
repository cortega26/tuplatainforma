---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import {
  CALCULATOR_DECISION_GUIDES,
  CALCULATOR_FAMILIES,
  CALCULATOR_FAMILY_ORDER,
  CALCULATOR_PORTFOLIO,
} from "@/config/calculatorPortfolio";
import CalculatorCard from "@/components/CalculatorCard.astro";
import { getPath } from "@/utils/getPath";

const groupedFamilies = CALCULATOR_FAMILY_ORDER.map(familyId => ({
  id: familyId,
  ...CALCULATOR_FAMILIES[familyId],
  calculators: CALCULATOR_PORTFOLIO.filter(calc => calc.family === familyId),
}));

const tagStyles: Record<string, string> = {
  "Más usada": "border-accent/30 bg-accent/10 text-accent",
  Contingencia:
    "border-[color:var(--color-accent-2)]/30 bg-[color:var(--color-accent-2)]/10 text-[color:var(--color-accent-2)]",
  "Decisión APV":
    "border-[color:var(--color-accent-2)]/30 bg-[color:var(--color-accent-2)]/10 text-[color:var(--color-accent-2)]",
  "Largo plazo": "border-accent/30 bg-accent/10 text-accent",
  "Oferta nueva":
    "border-[color:var(--color-highlight)]/30 bg-[color:var(--color-highlight)]/10 text-[color:var(--color-highlight)]",
  "Deuda usada":
    "border-[color:var(--color-highlight)]/30 bg-[color:var(--color-highlight)]/10 text-[color:var(--color-highlight)]",
  "Abono extra":
    "border-[color:var(--color-highlight)]/30 bg-[color:var(--color-highlight)]/10 text-[color:var(--color-highlight)]",
  "Salida formal":
    "border-[color:var(--color-highlight)]/30 bg-[color:var(--color-highlight)]/10 text-[color:var(--color-highlight)]",
  Referencia: "border-border bg-background text-secondary",
  Contrato: "border-border bg-background text-secondary",
};
---

<Layout
  title="Calculadoras Financieras en Chile | Monedario"
  description="Explora calculadoras gratuitas agrupadas por ingresos, previsión, deuda y UF para llegar más rápido a la herramienta correcta."
  enableClientRouter={false}
>
  <Header />
  <Breadcrumb />
  <main
    id="main-content"
    class="app-layout"
    data-analytics-page-type="calculator-index"
  >
    <section class="border-b border-border pt-8 pb-6">
      <h1 class="my-4 text-3xl font-bold sm:text-4xl">
        Calculadoras financieras para decisiones concretas
      </h1>
      <p class="max-w-3xl text-secondary">
        El portafolio ya no está ordenado como una lista plana. Partimos por la
        duda que quieres resolver y después por la familia correcta: ingresos,
        previsión, deuda o UF.
      </p>
      <p class="mt-3 text-sm text-secondary">
        {CALCULATOR_PORTFOLIO.length} herramientas activas agrupadas en{" "}
        {groupedFamilies.length} familias. Sin registro, sin pedir datos personales.
      </p>
    </section>

    <section class="py-8">
      <div
        class="rounded-xl border border-border bg-surface-muted/22 p-5 sm:p-6"
      >
        <div class="max-w-3xl">
          <h2 class="text-2xl font-semibold">Empieza por tu situación</h2>
          <p class="mt-2 text-sm leading-relaxed text-secondary">
            Si dos nombres te suenan parecidos, usa esta guía rápida antes de
            abrir una herramienta. La frontera importante es el trabajo que
            necesitas resolver, no la palabra “simulador”.
          </p>
        </div>

        <ol class="mt-6 grid gap-4 lg:grid-cols-2">
          {
            CALCULATOR_DECISION_GUIDES.map(guide => (
              <li class="rounded-lg border border-border bg-background p-4">
                <h3 class="text-lg leading-snug font-semibold">
                  {guide.title}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-secondary">
                  {guide.situation}
                </p>
                <p class="mt-3 text-sm leading-relaxed text-secondary">
                  Parte por{" "}
                  <a
                    href={getPath(guide.recommendedHref)}
                    class="font-semibold text-foreground underline decoration-border underline-offset-4 hover:text-accent"
                  >
                    {guide.recommendedLabel}
                  </a>
                  . {guide.why}
                </p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <div class="py-4">
      {
        groupedFamilies.map(family => (
          <section class="border-t border-border py-8 first:border-t-0 first:pt-0">
            <div class="grid gap-5 lg:grid-cols-[minmax(0,280px)_minmax(0,1fr)]">
              <div>
                <h2 class="text-2xl font-semibold">{family.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-secondary">
                  {family.description}
                </p>
                <p class="mt-3 text-sm leading-relaxed text-secondary">
                  {family.chooserPrompt}
                </p>
              </div>

              <ul class="grid gap-4 sm:grid-cols-2">
                {family.calculators.map(calc => (
                  <li>
                    <CalculatorCard
                      calc={calc}
                      familyId={family.id}
                      tagClass={
                        tagStyles[calc.tag] ??
                        "border-border bg-background text-secondary"
                      }
                    />
                  </li>
                ))}
              </ul>
            </div>
          </section>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>
