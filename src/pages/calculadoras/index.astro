---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getPath } from "@/utils/getPath";

const calculadoras = [
  {
    titulo: "Calculadora de Sueldo Líquido",
    descripcion:
      "¿Cuánto recibirás después de AFP, salud e impuestos? Obtén el desglose completo de tus descuentos.",
    href: getPath("/calculadoras/sueldo-liquido/"),
    icono: "💰",
    tag: "Más usada",
  },
  {
    titulo: "Conversor UF ↔ Pesos",
    descripcion:
      "Convierte entre UF y pesos al valor oficial del día. Incluye tabla de referencias rápidas.",
    href: getPath("/calculadoras/conversor-uf/"),
    icono: "🔄",
    tag: "Nueva",
  },
  {
    titulo: "Simulador APV",
    descripcion:
      "Compara Régimen A y B según tu sueldo y descubre cuál te ahorra más en impuestos.",
    href: getPath("/calculadoras/apv/"),
    icono: "📈",
    tag: "Nueva",
  },
  {
    titulo: "Costo Real Tarjeta de Crédito",
    descripcion:
      "Úsala si ya tienes deuda en la tarjeta y quieres medir el costo de pagar el mínimo o una cuota fija.",
    href: getPath("/calculadoras/tarjeta-credito/"),
    icono: "💳",
    tag: "Nueva",
  },
  {
    titulo: "Simulador de Jubilación",
    descripcion:
      "Proyecta tu saldo AFP al jubilar considerando la reforma previsional vigente y estima tu pensión.",
    href: getPath("/calculadoras/simulador-jubilacion/"),
    icono: "🏖️",
    tag: "Nueva",
  },
  {
    titulo: "Calculadora de Crédito de Consumo",
    descripcion:
      "Úsala para evaluar una oferta nueva de crédito de consumo: cuota, CAE e intereses totales.",
    href: getPath("/calculadoras/credito-consumo/"),
    icono: "🏦",
    tag: "Nueva",
  },
  {
    titulo: "Seguro de Cesantía",
    descripcion:
      "Estima tu saldo CIC y cuánto recibirías cada mes si quedaras sin trabajo según tu contrato y causal.",
    href: getPath("/calculadoras/seguro-cesantia/"),
    icono: "🛡️",
    tag: "Nueva",
  },
  {
    titulo: "Simulador Renegociación Superir",
    descripcion:
      "Ingresa tus deudas y verifica si calificas para la renegociación gratuita. Simula tu cuota.",
    href: getPath("/calculadoras/simulador-renegociacion/"),
    icono: "⚖️",
    tag: "Nueva",
  },
  {
    titulo: "¿Conviene prepagar el crédito?",
    descripcion:
      "Úsala si ya tienes un crédito vigente y estás evaluando un abono extraordinario versus invertir ese dinero.",
    href: getPath("/calculadoras/prepago-credito/"),
    icono: "💡",
    tag: "Nueva",
  },
  {
    titulo: "Reajuste de Arriendo",
    descripcion:
      "Calcula cuánto sube tu arriendo según la variación de la UF o el IPC. Para contratos en UF, IPC o pesos.",
    href: getPath("/calculadoras/reajuste-arriendo/"),
    icono: "🏠",
    tag: "Nueva",
  },
];

const tagStyles: Record<string, string> = {
  "Más usada": "bg-accent/20 text-accent",
  Nueva: "bg-green-500/20 text-green-500",
  Próximamente: "bg-foreground/10 text-muted",
};
---

<Layout
  title="Calculadoras Financieras en Chile | Monedario"
  description="Explora calculadoras gratuitas de sueldo líquido, APV, UF, crédito, cesantía, jubilación y más en un solo lugar."
>
  <Header />
  <Breadcrumb />
  <main
    id="main-content"
    class="app-layout"
    data-analytics-page-type="calculator-index"
  >
    <section class="border-b border-border pt-8 pb-6">
      <h1 class="my-4 text-3xl font-bold sm:text-4xl">
        🧮 Calculadoras Financieras
      </h1>
      <p class="max-w-xl text-secondary">
        Herramientas gratuitas para hacer tus propios números. Sin registro, sin
        datos personales.
      </p>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-border bg-foreground/5 p-5">
        <h2 class="mb-3 text-lg font-semibold">Elegir calculadora de deuda</h2>
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg border border-border bg-background p-4">
            <p class="mb-1 text-sm font-semibold">Oferta nueva</p>
            <p class="text-sm text-secondary">
              Si estás cotizando un préstamo antes de firmarlo, parte por
              <a href={getPath("/calculadoras/credito-consumo/")}>
                crédito de consumo
              </a>.
            </p>
          </div>
          <div class="rounded-lg border border-border bg-background p-4">
            <p class="mb-1 text-sm font-semibold">Deuda de tarjeta</p>
            <p class="text-sm text-secondary">
              Si ya usaste la tarjeta y quieres medir el costo del pago mínimo,
              usa
              <a href={getPath("/calculadoras/tarjeta-credito/")}>
                tarjeta de crédito
              </a>.
            </p>
          </div>
          <div class="rounded-lg border border-border bg-background p-4">
            <p class="mb-1 text-sm font-semibold">Abono extraordinario</p>
            <p class="text-sm text-secondary">
              Si el crédito ya existe y tu duda es si conviene prepagar, ve a
              <a href={getPath("/calculadoras/prepago-credito/")}>
                prepago de crédito
              </a>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-8">
      <ul class="grid gap-4 sm:grid-cols-2">
        {
          calculadoras.map(calc => (
            <li>
              <a
                href={calc.href}
                class:list={[
                  "block rounded-xl border border-border p-5",
                  "transition-all duration-200",
                  calc.tag === "Próximamente"
                    ? "cursor-not-allowed opacity-60"
                    : "hover:border-accent hover:bg-accent/5",
                ]}
                data-analytics-cta="calculator-index"
                data-analytics-label={calc.titulo}
                data-analytics-location="calculator_index"
              >
                <div class="mb-2 flex items-start justify-between gap-2">
                  <span class="text-2xl">{calc.icono}</span>
                  <span
                    class:list={[
                      "rounded-full px-2 py-0.5 text-xs font-bold",
                      tagStyles[calc.tag] ?? "bg-foreground/10 text-muted",
                    ]}
                  >
                    {calc.tag}
                  </span>
                </div>
                <h2 class="mb-1 text-lg font-semibold">{calc.titulo}</h2>
                <p class="text-sm text-secondary">{calc.descripcion}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
