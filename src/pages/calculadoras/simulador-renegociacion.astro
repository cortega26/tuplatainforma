---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getEconomicParameters } from "@/application/use-cases/GetEconomicParameters";
import { getPath } from "@/utils/getPath";

const renegociacionGuidePath = getPath("/posts/renegociacion-superir/");
const { parameters: economicParameters } = await getEconomicParameters();
const economicSourceLabel =
  economicParameters.source === "live"
    ? "dato en línea"
    : "fallback controlado";
---

<Layout
  title="Simulador de Renegociación de Deudas | Superir"
  description="Evalúa si cumples el filtro básico de renegociación Superir y separa esa revisión legal de una simulación orientativa de cuota."
>
  <Header />
  <Breadcrumb />
  <main
    id="main-content"
    class="app-layout"
    data-analytics-page-type="calculator"
    data-analytics-calculator="simulador-renegociacion"
    data-analytics-calculator-name="Simulador de Renegociacion Superir"
  >
    <section class="border-b border-border pt-8 pb-6">
      <h1 class="my-4 text-3xl font-bold sm:text-4xl">
        ⚖️ Simulador de Renegociación Superir
      </h1>
      <p class="max-w-xl text-secondary">
        Revisa primero si cumples el filtro básico de la Superir y, por
        separado, estima una cuota orientativa según tus deudas e ingresos.
      </p>
    </section>

    <section class="grid items-start gap-6 py-8 sm:grid-cols-2">
      <!-- FORMULARIO -->
      <div class="rounded-xl border border-border p-6">
        <h2 class="mb-5 text-lg font-semibold">📝 Tus deudas e ingresos</h2>

        <div class="mb-5">
          <p class="mb-3 text-sm font-medium text-secondary">
            Deudas vencidas (cada una con más de 90 días corridos)
          </p>
          <div id="deudas-container" class="space-y-3">
            <div class="deuda-row flex items-center gap-2">
              <input
                type="number"
                placeholder="Monto ($) Ej: 1.500.000"
                min="0"
                class="deuda-monto flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none"
              />
              <input
                type="number"
                placeholder="Días mora"
                min="1"
                max="5000"
                value="91"
                class="deuda-dias w-28 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none"
              />
            </div>
            <div class="deuda-row flex items-center gap-2">
              <input
                type="number"
                placeholder="Monto ($) Ej: 800.000"
                min="0"
                class="deuda-monto flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none"
              />
              <input
                type="number"
                placeholder="Días mora"
                min="1"
                max="5000"
                value="91"
                class="deuda-dias w-28 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none"
              />
            </div>
          </div>
          <button
            id="agregar-deuda"
            class="mt-2 text-xs text-accent hover:underline"
            >+ Agregar otra deuda</button
          >
          <p class="mt-1 text-xs text-muted">
            La regla legal no es "3 meses aproximados": cada deuda debe superar
            90 días corridos al momento de presentar la solicitud.
          </p>
        </div>

        <div class="mb-4">
          <label
            for="primera-categoria"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            ¿Tuviste inicio de actividades o rentas de primera categoría en los
            últimos 24 meses?
          </label>
          <select
            id="primera-categoria"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          >
            <option value="">Selecciona una opción</option>
            <option value="no">No</option>
            <option value="si">Sí</option>
          </select>
          <p class="mt-1 text-xs text-muted">
            Si emitiste boletas de honorarios, eso no equivale por sí solo a
            primera categoría.
          </p>
        </div>

        <div class="mb-4">
          <label
            for="juicio-ejecutivo"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            ¿Te notificaron formalmente una demanda ejecutiva o una liquidación
            forzosa?
          </label>
          <select
            id="juicio-ejecutivo"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          >
            <option value="">Selecciona una opción</option>
            <option value="no">No</option>
            <option value="si">Sí</option>
          </select>
        </div>

        <div class="mb-4">
          <label
            for="documentos-completos"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            ¿Ya tienes reunidos los documentos y declaraciones que pide la
            Superir?
          </label>
          <select
            id="documentos-completos"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          >
            <option value="">Selecciona una opción</option>
            <option value="si">Sí</option>
            <option value="no">No</option>
          </select>
          <p class="mt-1 text-xs text-muted">
            Esto no reemplaza la revisión de admisibilidad, pero sí cambia si tu
            caso está listo para solicitud formal o solo para evaluación.
          </p>
        </div>

        <div class="mb-4">
          <label
            for="ingreso"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Ingreso mensual neto ($)
          </label>
          <input
            type="number"
            id="ingreso"
            placeholder="Ej: 900.000"
            min="0"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
          <p class="mt-1 text-xs text-muted">
            Lo que recibes en tu cuenta (líquido).
          </p>
        </div>

        <div class="mb-4">
          <label
            for="plazo-renego"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Plazo de renegociación deseado (meses)
          </label>
          <input
            type="number"
            id="plazo-renego"
            placeholder="Ej: 36"
            min="6"
            max="120"
            value="36"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
        </div>

        <div class="mb-4">
          <label
            for="tasa-renego"
            class="mb-1 block text-sm font-medium text-secondary"
          >
            Tasa de interés del acuerdo (% mensual)
          </label>
          <input
            type="number"
            id="tasa-renego"
            placeholder="Ej: 1.5"
            min="0"
            max="5"
            step="0.1"
            value="1.5"
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-foreground focus:border-accent focus:outline-none"
          />
          <p class="mt-1 text-xs text-muted">
            La tasa varía según el acuerdo. Los acuerdos Superir suelen bajar la
            tasa respecto al contrato original. Usa 0% para simular cuota sin
            interés.
          </p>
        </div>

        <button
          id="calcBtn"
          class="mt-2 w-full rounded-lg bg-accent px-4 py-3 text-base font-bold text-background transition-opacity hover:opacity-90"
        >
          Simular renegociación →
        </button>
      </div>

      <!-- RESULTADO -->
      <div class="rounded-xl border border-border bg-background p-6">
        <h2 class="mb-5 text-lg font-semibold">📊 Diagnóstico y simulación</h2>
        <div
          id="resultado-contenido"
          data-guide-url={renegociacionGuidePath}
          data-uf={String(economicParameters.uf)}
          class="py-8 text-center text-muted"
        >
          <p class="mb-3 text-4xl">⚖️</p>
          <p class="text-sm">
            Ingresa tus deudas e ingresos para ver si calificas.
          </p>
        </div>
        <p class="mt-3 text-xs text-muted">
          Fuente económica: {economicSourceLabel} ({
            economicParameters.lastUpdated
          }).
        </p>
      </div>
    </section>

    <section
      class="prose prose-sm max-w-none border-t border-border pt-8 pb-12 dark:prose-invert"
    >
      <h2>¿Qué es la renegociación Superir?</h2>
      <p>
        La <strong
          >Superintendencia de Insolvencia y Reemprendimiento (Superir)</strong
        > ofrece un procedimiento gratuito donde actúa como mediadora entre tú y tus
        acreedores para acordar nuevas condiciones de pago. No necesitas abogado y
        más del 93% de quienes lo intentan llegan a acuerdo.
      </p>
      <ul>
        <li>
          <strong>Requisito clave:</strong> 2 o más deudas vencidas hace más de 90
          días corridos que sumen más de 80 UF en total.
        </li>
        <li>
          <strong>Resultado posible:</strong> cuota más baja, plazo más largo, tasa
          menor, meses de gracia o condonación de intereses.
        </li>
        <li>
          <strong>No aplica a:</strong> contribuyentes de primera categoría (empresas
          con actividad comercial) en los últimos 24 meses.
        </li>
        <li>
          <strong>También bloquea:</strong> haber sido notificado de un juicio ejecutivo
          o de una liquidación forzosa, y llegar sin la documentación requerida.
        </li>
      </ul>
      <p class="text-sm text-muted">
        ⚠️ Esta simulación es educativa. El bloque superior revisa un filtro
        legal básico y el bloque de cuota es solo una referencia financiera. La
        admisibilidad final la decide la Superir al revisar tus antecedentes.
        Para iniciar el trámite visita <a
          href="https://www.superir.gob.cl"
          target="_blank">superir.gob.cl</a
        >.
      </p>
      <p>
        Antes de iniciar la solicitud, revisa la <a
          href={renegociacionGuidePath}
          data-analytics-cta="calculator-guide"
          data-analytics-label="Guia de renegociacion Superir"
          data-analytics-location="calculator_explainer"
          >guía de renegociación Superir paso a paso</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { simulateDebtRenegotiation } from "@/application/use-cases/SimulateDebtRenegotiation";
  import { trackAnalyticsEvent } from "@/utils/analytics";

  function fmt(n: number) {
    return "$" + Math.round(n).toLocaleString("es-CL");
  }

  function fmtUF(n: number) {
    return n.toFixed(2) + " UF";
  }

  function buildRow(
    label: string,
    value: string,
    colorClass = ""
  ): HTMLDivElement {
    const line = document.createElement("div");
    line.className =
      "flex items-center justify-between border-b border-border py-2 text-sm last:border-0";

    const labelElement = document.createElement("span");
    labelElement.className = "text-secondary";
    labelElement.textContent = label;

    const valueElement = document.createElement("span");
    valueElement.className = `font-mono font-semibold ${colorClass}`.trim();
    valueElement.textContent = value;

    line.append(labelElement, valueElement);
    return line;
  }

  function buildChecklistLine(
    isValid: boolean,
    text: string
  ): HTMLParagraphElement {
    const line = document.createElement("p");
    line.textContent = `${isValid ? "✓" : "✗"} ${text}`;
    line.className = isValid ? "text-green-500" : "text-red-400";
    return line;
  }

  function createDebtRow(): HTMLDivElement {
    const row = document.createElement("div");
    row.className = "deuda-row flex items-center gap-2";

    const amountInput = document.createElement("input");
    amountInput.type = "number";
    amountInput.placeholder = "Monto ($)";
    amountInput.min = "0";
    amountInput.className =
      "deuda-monto flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none";

    const overdueInput = document.createElement("input");
    overdueInput.type = "number";
    overdueInput.placeholder = "Días mora";
    overdueInput.min = "1";
    overdueInput.max = "5000";
    overdueInput.value = "91";
    overdueInput.className =
      "deuda-dias w-28 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none";

    const removeButton = document.createElement("button");
    removeButton.type = "button";
    removeButton.textContent = "×";
    removeButton.className =
      "eliminar-deuda text-lg leading-none text-muted hover:text-red-400";
    removeButton.addEventListener("click", () => row.remove());

    row.append(amountInput, overdueInput, removeButton);
    return row;
  }

  // Agregar deuda
  document.getElementById("agregar-deuda")?.addEventListener("click", () => {
    const container = document.getElementById("deudas-container")!;
    container.appendChild(createDebtRow());
  });

  document.getElementById("calcBtn")?.addEventListener("click", () => {
    const resultContainer = document.getElementById("resultado-contenido");
    const guideUrl = resultContainer?.dataset?.guideUrl;
    const ufValue = Number(resultContainer?.dataset?.uf);
    if (!guideUrl || !Number.isFinite(ufValue) || ufValue <= 0) return;

    const filas = document.querySelectorAll(".deuda-row");
    const deudas: { monto: number; dias: number }[] = [];

    filas.forEach(fila => {
      const monto =
        parseFloat(
          (fila.querySelector(".deuda-monto") as HTMLInputElement).value
        ) || 0;
      const dias =
        parseInt(
          (fila.querySelector(".deuda-dias") as HTMLInputElement).value
        ) || 0;
      if (monto > 0) deudas.push({ monto, dias });
    });

    const ingreso =
      parseFloat(
        (document.getElementById("ingreso") as HTMLInputElement).value
      ) || 0;
    const plazo =
      parseInt(
        (document.getElementById("plazo-renego") as HTMLInputElement).value
      ) || 36;
    const tasaMensual =
      parseFloat(
        (document.getElementById("tasa-renego") as HTMLInputElement).value
      ) / 100;
    const primeraCategoria = (
      document.getElementById("primera-categoria") as HTMLSelectElement
    ).value;
    const juicioEjecutivo = (
      document.getElementById("juicio-ejecutivo") as HTMLSelectElement
    ).value;
    const documentosCompletos = (
      document.getElementById("documentos-completos") as HTMLSelectElement
    ).value;

    if (
      deudas.length === 0 ||
      ingreso <= 0 ||
      !primeraCategoria ||
      !juicioEjecutivo ||
      !documentosCompletos
    ) {
      alert(
        "Completa al menos una deuda, tu ingreso y las preguntas legales antes de simular."
      );
      return;
    }

    let simulacion;
    try {
      simulacion = simulateDebtRenegotiation({
        debts: deudas.map(deuda => ({
          amount: deuda.monto,
          overdueDays: deuda.dias,
        })),
        monthlyIncome: ingreso,
        termMonths: plazo,
        monthlyRatePercent: tasaMensual * 100,
        ufValue,
        hasFirstCategoryActivityLast24Months: primeraCategoria === "si",
        hasNotifiedExecutiveProceeding: juicioEjecutivo === "si",
        hasRequiredDocuments: documentosCompletos === "si",
      });
    } catch (error) {
      alert(
        error instanceof Error
          ? error.message
          : "No se pudo simular la renegociación."
      );
      return;
    }

    const container = document.getElementById("resultado-contenido")!;

    const statusBox = document.createElement("div");
    statusBox.className = `mb-5 rounded-lg border p-4 ${
      simulacion.canSubmitApplication
        ? "border-green-500/30 bg-green-500/5"
        : simulacion.meetsBasicEligibility
          ? "border-yellow-500/30 bg-yellow-500/10"
          : "border-red-500/30 bg-red-500/10"
    }`;

    const statusTitle = document.createElement("p");
    statusTitle.className = `mb-3 text-base font-bold ${
      simulacion.canSubmitApplication
        ? "text-green-500"
        : simulacion.meetsBasicEligibility
          ? "text-yellow-500"
          : "text-red-400"
    }`;
    statusTitle.textContent = simulacion.canSubmitApplication
      ? "✓ Cumples el filtro básico y podrías preparar la solicitud"
      : simulacion.meetsBasicEligibility
        ? "⚠️ Cumples el filtro básico, pero aún no estás listo para calificar formalmente"
        : "✗ No cumples el filtro básico de elegibilidad";

    const checklist = document.createElement("div");
    checklist.className = "space-y-1.5 text-sm";
    checklist.append(
      buildChecklistLine(
        simulacion.requirementChecks.hasTwoOrMoreDebts,
        `2 o más deudas distintas: ${deudas.length} ingresada${deudas.length > 1 ? "s" : ""}`
      ),
      buildChecklistLine(
        simulacion.requirementChecks.hasTwoOrMoreQualifiedDebts,
        `Con más de 90 días corridos: ${simulacion.qualifiedDebtCount} califican`
      ),
      buildChecklistLine(
        simulacion.requirementChecks.reachesMinimumUf,
        `Total supera ${simulacion.minimumDebtUf} UF: ${fmtUF(simulacion.qualifiedDebtUf)} (mín. ${simulacion.minimumDebtUf} UF = ${fmt(simulacion.minimumDebtUf * ufValue)})`
      ),
      buildChecklistLine(
        simulacion.requirementChecks.hasNoFirstCategoryActivity,
        "Sin actividad de primera categoría en los últimos 24 meses"
      ),
      buildChecklistLine(
        simulacion.requirementChecks.hasNoNotifiedExecutiveProceeding,
        "Sin juicio ejecutivo ni liquidación forzosa notificada"
      ),
      buildChecklistLine(
        simulacion.requirementChecks.hasRequiredDocuments,
        "Documentos y declaraciones listos para presentar la solicitud"
      )
    );
    const statusNote = document.createElement("p");
    statusNote.className = "mt-3 text-xs text-secondary";
    statusNote.textContent = simulacion.canSubmitApplication
      ? "Esto no garantiza admisión automática: la revisión formal final depende de la Superir y de tus respaldos."
      : simulacion.meetsBasicEligibility
        ? "Tu caso podría ser renegociable, pero todavía no equivale a 'calificas formalmente'. Te faltan antecedentes para presentar la solicitud."
        : "La cuota de abajo sigue siendo solo una simulación financiera orientativa. No corrige exclusiones legales ni reemplaza asesoría.";
    statusBox.append(statusTitle, checklist, statusNote);

    const burdenColorClass =
      simulacion.incomeBurdenPercent <= 30
        ? "text-green-500"
        : simulacion.incomeBurdenPercent <= 50
          ? "text-yellow-500"
          : "text-red-400";

    const simulationSection = document.createElement("div");
    simulationSection.className = "mt-5";
    const simulationLabel = document.createElement("p");
    simulationLabel.className = "mb-2 text-xs font-bold text-muted uppercase";
    simulationLabel.textContent = `Simulación financiera orientativa — ${plazo} meses`;
    simulationSection.append(
      simulationLabel,
      buildRow(
        "Cuota mensual estimada",
        fmt(simulacion.monthlyPayment),
        burdenColorClass
      ),
      buildRow(
        "Como % de tu ingreso",
        `${simulacion.incomeBurdenPercent.toFixed(1)}%`,
        burdenColorClass
      ),
      buildRow("Total a pagar", fmt(simulacion.totalPaid)),
      buildRow("Intereses del acuerdo", fmt(simulacion.totalInterest))
    );

    const advisory = document.createElement("div");
    advisory.className =
      "mt-3 rounded-lg bg-foreground/5 p-3 text-xs text-secondary";
    advisory.textContent =
      simulacion.incomeBurdenPercent <= 30
        ? "✅ La cuota simulada es manejable (≤30% de tu ingreso). Úsala como punto de partida para armar tu propuesta, no como aprobación legal."
        : simulacion.incomeBurdenPercent <= 50
          ? "⚠️ La cuota es alta (30–50% del ingreso). Considera extender el plazo o negociar intereses antes de presentar una propuesta."
          : "🔴 La cuota supera el 50% de tu ingreso. Antes de pensar en admisibilidad, revisa si tu propuesta es realmente pagable o si necesitas otra salida.";

    const guideLink = document.createElement("a");
    guideLink.href = guideUrl;
    guideLink.className =
      "mt-4 block text-center text-xs text-accent hover:underline";
    guideLink.dataset.analyticsCta = "calculator-guide";
    guideLink.dataset.analyticsLabel = "Guia de renegociacion Superir";
    guideLink.dataset.analyticsLocation = "calculator_result";
    guideLink.textContent = "→ Leer guía completa de la renegociación Superir";

    container.replaceChildren(
      statusBox,
      buildRow("Total deuda declarada", fmt(simulacion.totalDebtClp)),
      buildRow("En UF", fmtUF(simulacion.totalDebtUf)),
      simulationSection,
      advisory,
      guideLink
    );

    trackAnalyticsEvent("calculator_complete", {
      calculator_slug: "simulador-renegociacion",
      calculator_name: "Simulador de Renegociacion Superir",
      outcome: simulacion.canSubmitApplication
        ? "basic-filter-pass"
        : simulacion.meetsBasicEligibility
          ? "missing-documents"
          : "basic-filter-fail",
    });
  });
</script>
