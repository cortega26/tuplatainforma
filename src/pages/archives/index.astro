---
import { getCollection, type CollectionEntry } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import postFilter from "@/utils/postFilter";
import { SITE } from "@/config";

// Redirect to 404 page if `showArchives` config is false
const showArchives = Boolean(SITE.showArchives);
if (!showArchives) {
  return Astro.redirect(new URL("404/", SITE.website).pathname);
}

type BlogPost = CollectionEntry<"blog">;

type ArchiveMonth = {
  label: string;
  month: number;
  posts: BlogPost[];
  href: string;
};

type ArchiveYear = {
  year: number;
  posts: BlogPost[];
  months: ArchiveMonth[];
};

const posts = (await getCollection("blog")).filter(postFilter);

const months = [
  "Enero",
  "Febrero",
  "Marzo",
  "Abril",
  "Mayo",
  "Junio",
  "Julio",
  "Agosto",
  "Septiembre",
  "Octubre",
  "Noviembre",
  "Diciembre",
];

const archiveDateFormatter = new Intl.DateTimeFormat("es-CL", {
  timeZone: SITE.timezone,
  year: "numeric",
  month: "numeric",
});

const getArchiveYearMonth = (date: Date) => {
  const parts = archiveDateFormatter.formatToParts(date);
  const year = Number(parts.find(part => part.type === "year")?.value);
  const month = Number(parts.find(part => part.type === "month")?.value);

  return { year, month };
};

const getPostTimestamp = (post: BlogPost) => post.data.pubDate.getTime();

const sortedPosts = [...posts].sort(
  (a, b) => getPostTimestamp(b) - getPostTimestamp(a)
);

const archiveMap = new Map<number, Map<number, BlogPost[]>>();

for (const post of sortedPosts) {
  const { year, month } = getArchiveYearMonth(post.data.pubDate);
  const yearMap = archiveMap.get(year) ?? new Map<number, BlogPost[]>();
  const monthPosts = yearMap.get(month) ?? [];

  monthPosts.push(post);
  yearMap.set(month, monthPosts);
  archiveMap.set(year, yearMap);
}

const archiveYears: ArchiveYear[] = [...archiveMap.entries()]
  .sort(([yearA], [yearB]) => yearB - yearA)
  .map(([year, monthMap]) => {
    const monthsForYear = [...monthMap.entries()]
      .sort(([monthA], [monthB]) => monthB - monthA)
      .map(([month, monthPosts]) => ({
        label: months[month - 1],
        month,
        posts: monthPosts,
        href: `${Astro.url.pathname}?year=${year}&month=${month}#archive-${year}-${String(month).padStart(2, "0")}`,
      }));

    return {
      year,
      posts: monthsForYear.flatMap(monthGroup => monthGroup.posts),
      months: monthsForYear,
    };
  });
---

<Layout title={`Archivo | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Archivo" pageDesc="Todos los artículos archivados.">
    <section
      class="mb-10 rounded-xl border border-border bg-surface-muted p-5"
      data-archive-root
    >
      <div
        class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
      >
        <p class="text-sm text-secondary">
          Explora por año y filtra por mes sin salir de esta página.
        </p>
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4"
          data-archive-status
          hidden
        >
          <p class="text-sm text-secondary" data-archive-status-label></p>
          <a
            href={Astro.url.pathname}
            data-archive-clear
            class="inline-flex w-fit items-center gap-2 rounded-md border border-border px-3 py-1.5 text-sm font-medium text-secondary transition-colors hover:border-accent hover:text-accent"
          >
            Ver todo el archivo
          </a>
        </div>
      </div>

      <div class="mt-6 space-y-6">
        {
          archiveYears.map(yearGroup => (
            <section>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold">{yearGroup.year}</span>
                <sup class="text-sm">{yearGroup.posts.length}</sup>
              </div>

              <div class="mt-3 flex flex-wrap gap-3">
                {yearGroup.months.map(monthGroup => (
                  <a
                    href={monthGroup.href}
                    data-archive-filter
                    data-year={yearGroup.year}
                    data-month={monthGroup.month}
                    data-label={`${monthGroup.label} ${yearGroup.year}`}
                    class:list={[
                      "inline-flex items-baseline gap-1 rounded-md border px-3 py-2 text-sm font-medium transition-colors",
                      "border-border text-secondary hover:border-accent hover:text-accent",
                    ]}
                  >
                    <span>{monthGroup.label}</span>
                    <sup class="text-xs">{monthGroup.posts.length}</sup>
                  </a>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </section>

    {
      archiveYears.map(yearGroup => (
        <section
          class="mb-12"
          data-archive-year
          data-year={yearGroup.year}
          data-total-count={yearGroup.posts.length}
        >
          <div class="mb-6 flex items-baseline gap-2">
            <h2 class="text-2xl font-bold">{yearGroup.year}</h2>
            <sup class="text-sm" data-archive-year-count>
              {yearGroup.posts.length}
            </sup>
          </div>

          {yearGroup.months.map(monthGroup => (
            <div
              id={`archive-${yearGroup.year}-${String(monthGroup.month).padStart(2, "0")}`}
              class="mb-10"
              data-archive-month
              data-year={yearGroup.year}
              data-month={monthGroup.month}
              data-count={monthGroup.posts.length}
              data-label={`${monthGroup.label} ${yearGroup.year}`}
            >
              <div class="mb-4 flex items-baseline gap-2">
                <h3 class="text-xl font-bold">{monthGroup.label}</h3>
                <sup class="text-xs">{monthGroup.posts.length}</sup>
              </div>

              <ul>
                {monthGroup.posts.map(data => (
                  <Card {...data} />
                ))}
              </ul>
            </div>
          ))}
        </section>
      ))
    }
  </Main>
  <Footer />
</Layout>

<script>
  const archiveRoot = document.querySelector("[data-archive-root]");

  if (archiveRoot instanceof HTMLElement) {
    const filterLinks = Array.from(
      archiveRoot.querySelectorAll("[data-archive-filter]")
    ) as HTMLAnchorElement[];
    const status = archiveRoot.querySelector("[data-archive-status]");
    const statusLabel = archiveRoot.querySelector(
      "[data-archive-status-label]"
    );
    const clearLink = archiveRoot.querySelector("[data-archive-clear]");
    const yearSections = Array.from(
      document.querySelectorAll("[data-archive-year]")
    ) as HTMLElement[];
    const monthSections = Array.from(
      document.querySelectorAll("[data-archive-month]")
    ) as HTMLElement[];
    const inactiveClasses = [
      "border-border",
      "text-secondary",
      "hover:border-accent",
      "hover:text-accent",
    ];

    const getSelection = (): { year: number; month: number } | null => {
      const params = new URLSearchParams(window.location.search);
      const year = Number(params.get("year"));
      const month = Number(params.get("month"));

      if (!Number.isInteger(year) || !Number.isInteger(month)) {
        return null;
      }

      return { year, month };
    };

    const setLinkState = (link: HTMLAnchorElement, isActive: boolean) => {
      link.classList.toggle("border-accent", isActive);
      link.classList.toggle("bg-accent/10", isActive);
      link.classList.toggle("text-accent", isActive);

      for (const className of inactiveClasses) {
        link.classList.toggle(className, !isActive);
      }

      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    };

    const renderFilter = () => {
      let selection = getSelection();
      const activeLink = filterLinks.find(link => {
        const year = Number(link.getAttribute("data-year"));
        const month = Number(link.getAttribute("data-month"));
        return (
          selection && year === selection.year && month === selection.month
        );
      });

      if (!activeLink) {
        selection = null;
      }

      for (const link of filterLinks) {
        setLinkState(link, link === activeLink);
      }

      for (const monthSection of monthSections) {
        const year = Number(monthSection.getAttribute("data-year"));
        const month = Number(monthSection.getAttribute("data-month"));
        const isVisible =
          !selection || (year === selection.year && month === selection.month);

        monthSection.toggleAttribute("hidden", !isVisible);
      }

      for (const yearSection of yearSections) {
        const year = Number(yearSection.getAttribute("data-year"));
        const totalCount = Number(yearSection.getAttribute("data-total-count"));
        const countNode = yearSection.querySelector(
          "[data-archive-year-count]"
        );
        const visibleMonths = monthSections.filter(
          monthSection =>
            Number(monthSection.getAttribute("data-year")) === year &&
            !monthSection.hasAttribute("hidden")
        );

        yearSection.toggleAttribute("hidden", visibleMonths.length === 0);

        if (countNode instanceof HTMLElement) {
          const visibleCount = visibleMonths.reduce(
            (sum, monthSection) =>
              sum + Number(monthSection.getAttribute("data-count") ?? "0"),
            0
          );

          countNode.textContent = String(
            selection && year === selection.year ? visibleCount : totalCount
          );
        }
      }

      if (
        status instanceof HTMLElement &&
        statusLabel instanceof HTMLElement &&
        clearLink instanceof HTMLAnchorElement
      ) {
        status.hidden = !selection;

        if (selection && activeLink instanceof HTMLAnchorElement) {
          statusLabel.textContent = `Mostrando solo ${activeLink.getAttribute("data-label")}.`;
          clearLink.href = window.location.pathname;
        } else {
          statusLabel.textContent = "";
        }
      }
    };

    for (const link of filterLinks) {
      if (!(link instanceof HTMLAnchorElement)) continue;

      link.addEventListener("click", event => {
        event.preventDefault();
        const url = new URL(link.href, window.location.origin);
        window.history.pushState(
          {},
          "",
          `${url.pathname}${url.search}${url.hash}`
        );
        renderFilter();

        const targetId = url.hash.replace("#", "");
        const target = targetId ? document.getElementById(targetId) : null;
        target?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    }

    if (clearLink instanceof HTMLAnchorElement) {
      clearLink.addEventListener("click", event => {
        event.preventDefault();
        window.history.pushState({}, "", window.location.pathname);
        renderFilter();
      });
    }

    window.addEventListener("popstate", renderFilter);
    renderFilter();
  }
</script>
