---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getPath } from "@/utils/getPath";
import { getHubArticleAssignments } from "@/config/editorial-hub-model.mjs";

const hubAssignments = getHubArticleAssignments("deuda-credito");
---

<Layout
  title="Deuda y Crédito en Chile | Monedario"
  description="Guías y artículos sobre deuda y crédito en Chile para entender informes comerciales, renegociación y costo total del crédito."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <!-- Removed Authority Layer tag -->
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Deuda y Crédito en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Esta sección te ayuda a entender tu nivel de deuda, revisar opciones
        para salir de un problema financiero y entender cuánto termina costando
        un crédito. Si tu duda principal es UF, IPC o costo de vida, ese frente
        no vive en el núcleo de deuda: aquí solo lo enlazamos cuando aparece
        dentro de una obligación reajustable.
      </p>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Temas que puedes revisar</h2>
      <ul class="grid gap-4">
        {
          hubAssignments.core.map(
            (item: (typeof hubAssignments.core)[number]) => (
              <li class="rounded-xl border border-border p-5">
                <h3 class="mb-2 text-lg font-semibold">{item.title}</h3>
                <p class="mb-3 text-sm text-secondary">{item.summary}</p>
                <a
                  href={getPath(item.href)}
                  class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
                >
                  Leer artículo
                </a>
              </li>
            )
          )
        }
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Empieza aquí si...</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          Necesitas saber qué deudas aparecen realmente a tu nombre: parte por{
            " "
          }
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/informe-deudas-cmf-vs-dicom/")}
          >
            Informe de Deudas CMF vs DICOM
          </a>
          .
        </li>
        <li>
          Quieres comparar bien el costo total de un crédito antes de firmar:
          revisa{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/cae-costo-real-credito-chile/")}
          >
            la guía de CAE y costo real
          </a>
          .
        </li>
        <li>
          Ya estás en mora y buscas una salida formal: continúa con{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/renegociacion-superir/")}
          >
            renegociación en Superir
          </a>
          .
        </li>
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">
        Relacionado, pero fuera del núcleo deuda
      </h2>
      {
        hubAssignments.related.map(
          (item: (typeof hubAssignments.related)[number]) => (
            <div class="rounded-xl border border-border p-5">
              <h3 class="mb-2 text-lg font-semibold">{item.title}</h3>
              <p class="mb-3 text-sm text-secondary">
                {item.summary} {item.rationale}
              </p>
              <a
                href={getPath(item.href)}
                class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                Ir a la guía relacionada
              </a>
            </div>
          )
        )
      }
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Errores comunes</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          Tomar decisiones de crédito sin revisar primero todas tus deudas
          vigentes.
        </li>
        <li>
          Postergar la renegociación hasta acumular más mora y menor margen de
          negociación real.
        </li>
        <li>
          Ignorar el efecto de UF e intereses en el costo total de una deuda de
          mediano o largo plazo.
        </li>
      </ul>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <h2 class="mb-2 text-xl font-bold">
          Última actualización de la sección
        </h2>
        <p class="text-sm text-secondary">
          Actualizado: 2026-03-12. Esta sección se revisa cuando cambian reglas
          de reporte comercial, requisitos de renegociación o condiciones
          relevantes de crédito en Chile, o cuando un activo relacionado deja de
          pertenecer al núcleo editorial de deuda.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
