---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getPath } from "@/utils/getPath";

const articulosSeccion = [
  {
    titulo:
      "Te hicieron un cargo que no reconoces: qué hacer en las primeras 24 horas (Ley 20.009)",
    resumen:
      "Qué hacer para bloquear, reclamar e intentar recuperar tu plata si ya hubo fraude.",
    href: getPath("/posts/fraude-tarjeta-que-hacer/"),
  },
  {
    titulo:
      "Estafas financieras en Chile: señales por canal y checklist de 24 horas",
    resumen:
      "Guía preventiva por canal para reducir riesgo antes de que exista pérdida de dinero.",
    href: getPath(
      "/posts/estafas-financieras-chile-vishing-smishing-marketplace/"
    ),
  },
  {
    titulo:
      "Suplantación de identidad y créditos no reconocidos: qué hacer paso a paso",
    resumen:
      "Qué hacer para detectar la suplantación, reunir pruebas y reclamar ante la institución.",
    href: getPath("/posts/suplantacion-identidad-creditos-no-reconocidos/"),
  },
];
---

<Layout
  title="Seguridad Financiera en Chile | Monedario"
  description="Guías y artículos para prevenir estafas, actuar ante fraudes y resolver casos de suplantación de identidad en Chile."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <!-- Removed Authority Layer tag -->
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Seguridad Financiera en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Esta sección reúne guías para prevenir estafas, reaccionar ante cargos
        no reconocidos y actuar si usaron tu identidad para pedir créditos o
        abrir productos.
      </p>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Temas que puedes revisar</h2>
      <ul class="grid gap-4">
        {
          articulosSeccion.map(item => (
            <li class="rounded-xl border border-border p-5">
              <h3 class="mb-2 text-lg font-semibold">{item.titulo}</h3>
              <p class="mb-3 text-sm text-secondary">{item.resumen}</p>
              <a
                href={item.href}
                class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                Leer artículo
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Empieza aquí si...</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          Detectaste un movimiento no autorizado hoy: parte por{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/fraude-tarjeta-que-hacer/")}
          >
            fraude en primeras 24 horas
          </a>
          .
        </li>
        <li>
          Quieres prevenir antes de que pase algo: revisa{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath(
              "/posts/estafas-financieras-chile-vishing-smishing-marketplace/"
            )}
          >
            señales por canal y checklist preventivo
          </a>
          .
        </li>
        <li>
          Apareció deuda o crédito que no reconoces: continúa con{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath(
              "/posts/suplantacion-identidad-creditos-no-reconocidos/"
            )}
          >
            suplantación y créditos no reconocidos
          </a>
          .
        </li>
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Errores comunes</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>Actuar tarde por esperar “confirmación” del fraude.</li>
        <li>
          Entregar códigos de verificación en llamadas o mensajes urgentes.
        </li>
        <li>No guardar evidencia ni folios para sostener el reclamo formal.</li>
      </ul>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <h2 class="mb-2 text-xl font-bold">
          Última actualización de la sección
        </h2>
        <p class="text-sm text-secondary">
          Actualizado: 2026-03-02. Esta sección se revisa cuando cambian las
          reglas para devolver dinero por fraude, los canales más usados en
          estafas o las instrucciones oficiales en Chile.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
