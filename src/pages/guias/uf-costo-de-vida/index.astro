---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getPath } from "@/utils/getPath";
import { getHubArticleAssignments } from "@/config/editorial-hub-model.mjs";

const hubAssignments = getHubArticleAssignments("uf-costo-de-vida");

const tools = [
  {
    title: "Conversor UF a pesos",
    description:
      "Úsalo cuando ya entendiste la lógica de la UF y necesitas pasar un monto a CLP o volver de pesos a UF con valor de referencia.",
    href: getPath("/calculadoras/conversor-uf/"),
    cta: "Abrir conversor",
  },
  {
    title: "Calculadora de reajuste de arriendo",
    description:
      "Sirve para aterrizar una cláusula en UF, IPC o pesos fijos y estimar cuánto cambia realmente tu pago mensual.",
    href: getPath("/calculadoras/reajuste-arriendo/"),
    cta: "Abrir calculadora",
  },
];

const relatedBridges = [
  {
    title: "Deuda y crédito",
    description:
      "Cruza a esta sección solo cuando la duda principal ya no es inflación o bolsillo, sino el costo total de una obligación financiera reajustable.",
    href: getPath("/guias/deuda-credito/"),
  },
];

const futureAdditions = [
  "Hardening puntual de metadata/frontmatter para mover juntos UF, IPC y reajuste al cluster canónico sin abrir una migración masiva.",
  "Ajuste fino de bridges desde activos vecinos si aparece una nueva necesidad causal real, no por inflar enlazado.",
];
---

<Layout
  title="UF, inflación y costo de vida en Chile | Monedario"
  description="Guía temática para entender cómo se conectan UF, IPC, reajustes y herramientas prácticas de costo de vida en Chile."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <p
        class="mb-2 text-xs font-semibold tracking-widest text-accent uppercase"
      >
        Guía temática
      </p>
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        UF, inflación y costo de vida en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Esta sección ordena una misma historia editorial: cómo el IPC mueve la
        inflación, cómo esa inflación se traduce a UF y cómo ambos terminan
        pegando en arriendos, cuotas y gastos reales. Aquí el foco no es la
        macro por sí sola, sino el impacto práctico en tu bolsillo y en
        contratos reajustables de todos los días.
      </p>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Base editorial del frente</h2>
      <ul class="grid gap-4">
        {
          hubAssignments.core.map(
            (item: (typeof hubAssignments.core)[number]) => (
              <li class="rounded-xl border border-border p-5">
                <p class="mb-2 text-xs font-semibold tracking-wide text-accent uppercase">
                  Core explainer
                </p>
                <h3 class="mb-2 text-lg font-semibold">{item.title}</h3>
                <p class="mb-3 text-sm text-secondary">{item.summary}</p>
                <a
                  href={getPath(item.href)}
                  class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
                >
                  Leer artículo
                </a>
              </li>
            )
          )
        }
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">
        Herramientas para pasar del concepto al número
      </h2>
      <div class="grid gap-4 md:grid-cols-2">
        {
          tools.map(tool => (
            <article class="rounded-xl border border-border p-5">
              <p class="mb-2 text-xs font-semibold tracking-wide text-accent uppercase">
                Tool
              </p>
              <h3 class="text-lg font-semibold">{tool.title}</h3>
              <p class="mt-2 text-sm text-secondary">{tool.description}</p>
              <a
                href={tool.href}
                class="mt-4 inline-flex text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                {tool.cta}
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Empieza aquí si...</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          Quieres entender por qué un monto en UF cambia en pesos: parte por{
            " "
          }
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/que-es-la-uf/")}
          >
            qué es la UF
          </a>
          .
        </li>
        <li>
          Necesitas entender el dato de inflación antes de mirar un contrato:
          sigue con{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/que-es-el-ipc-chile-como-se-calcula/")}
          >
            la guía del IPC
          </a>
          .
        </li>
        <li>
          Tienes una cláusula de arriendo y quieres traducirla a un pago real:
          lee{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/reajuste-arriendo-uf-ipc-chile/")}
          >
            reajuste de arriendo en Chile
          </a>{" "}
          y después usa la calculadora.
        </li>
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Transición operativa explícita</h2>
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <p class="text-sm text-secondary">
          Este hub ya es la entrada editorial correcta del frente, pero no finge
          una migración total. Por ahora,{" "}
          <strong><code>que-es-la-uf</code></strong> y{" "}
          <strong><code>reajuste-arriendo-uf-ipc-chile</code></strong> siguen publicados
          con placement operativo heredado desde <strong>deuda-credito</strong>,
          y <strong><code>que-es-el-ipc-chile-como-se-calcula</code></strong>{
            " "
          }
          sigue con placement heredado desde <strong>empleo-ingresos</strong>.
          Aquí se ordenan como núcleo canónico del frente sin forzar todavía una
          pasada masiva de metadata o runtime.
        </p>
      </div>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">
        Relacionado, pero fuera del núcleo de costo de vida
      </h2>
      <div class="grid gap-4 md:grid-cols-2">
        {
          relatedBridges.map(item => (
            <article class="rounded-xl border border-border p-5">
              <p class="mb-2 text-xs font-semibold tracking-wide text-accent uppercase">
                Related bridge
              </p>
              <h3 class="text-lg font-semibold">{item.title}</h3>
              <p class="mt-2 text-sm text-secondary">{item.description}</p>
              <a
                href={item.href}
                class="mt-4 inline-flex text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                Ir a esa sección
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-border p-6">
        <h2 class="mb-4 text-xl font-bold">Lo que no migramos todavía</h2>
        <ul class="list-disc space-y-2 pl-6 text-secondary">
          {futureAdditions.map(item => <li>{item}</li>)}
        </ul>
        <p class="mt-4 text-sm text-secondary">
          Actualizado: 2026-03-12. Esta sección se revisa cuando cambian
          metodología UF/IPC, emerge una herramienta nueva del frente o se abre
          la pasada puntual de hardening para alinear metadata con ownership
          canónico.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
