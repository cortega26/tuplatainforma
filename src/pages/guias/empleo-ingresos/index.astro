---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getPath } from "@/utils/getPath";

const articulosSeccion = [
  {
    titulo:
      "Seguro de cesantía: cómo saber tu saldo, cuándo puedes cobrar y cuánto te pagan",
    resumen:
      "Explica cuánto tienes, cuándo puedes cobrar y qué necesitas para pedir el seguro de cesantía.",
    href: getPath("/posts/seguro-de-cesantia/"),
  },
  {
    titulo: "Licencia médica en Chile: desde qué día te pagan y cómo reclamar",
    resumen:
      "Explica desde qué día te pagan, qué hacer si la rechazan y cómo reclamar.",
    href: getPath("/posts/licencia-medica-desde-que-dia-pagan/"),
  },
  {
    titulo:
      "Finiquito e indemnizaciones en Chile: qué te corresponde y cómo revisarlo",
    resumen:
      "Qué revisar en tu finiquito para no firmar con errores de cálculo.",
    href: getPath("/posts/finiquito-e-indemnizaciones-en-chile/"),
  },
];
---

<Layout
  title="Contingencias de Empleo e Ingresos en Chile | Monedario"
  description="Guías y artículos sobre cesantía, licencias médicas y finiquito para saber qué hacer cuando se interrumpe tu ingreso laboral."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <!-- Removed Authority Layer tag -->
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Contingencias de Empleo e Ingresos en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Esta sección reúne ayudas para cuando el ingreso laboral se interrumpe:
        cesantía, licencia médica o término de contrato con finiquito e
        indemnizaciones. Si tu duda es la liquidación mensual o el sueldo
        líquido, parte mejor por la sección de{" "}
        <a
          href={getPath("/guias/sueldo-remuneraciones/")}
          class="text-accent underline underline-offset-4 hover:opacity-80"
        >
          sueldo y remuneraciones
        </a>
        .
      </p>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Temas que puedes revisar</h2>
      <ul class="grid gap-4">
        {
          articulosSeccion.map(item => (
            <li class="rounded-xl border border-border p-5">
              <h3 class="mb-2 text-lg font-semibold">{item.titulo}</h3>
              <p class="mb-3 text-sm text-secondary">{item.resumen}</p>
              <a
                href={item.href}
                class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                Leer artículo
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Empieza aquí si...</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          Te quedaste sin trabajo y necesitas liquidez rápida: parte por{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/seguro-de-cesantia/")}
          >
            seguro de cesantía
          </a>
          .
        </li>
        <li>
          Tienes licencia y no entiendes pagos o rechazos: revisa{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/licencia-medica-desde-que-dia-pagan/")}
          >
            licencia médica y apelación
          </a>
          .
        </li>
        <li>
          Estás cerrando contrato y debes firmar finiquito: continúa con{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/finiquito-e-indemnizaciones-en-chile/")}
          >
            finiquito e indemnizaciones
          </a>
          .
        </li>
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Errores comunes</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          No revisar plazos de reclamo y notificación en contingencias
          laborales.
        </li>
        <li>
          Firmar documentos de cierre sin revisar el cálculo y la causal de
          término.
        </li>
        <li>
          Tratar cesantía, licencia y finiquito como temas aislados cuando
          afectan la misma caja.
        </li>
      </ul>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <h2 class="mb-2 text-xl font-bold">
          Última actualización de la sección
        </h2>
        <p class="text-sm text-secondary">
          Actualizado: 2026-03-02. Esta sección se revisa cuando cambian reglas
          de subsidios, cesantía, finiquito o normativa laboral con impacto
          directo en ingresos.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
