---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { GUIDE_HUB_ORDER, GUIDE_HUBS } from "@/config/clusters";
import { getPath } from "@/utils/getPath";

const capas = [
  {
    id: "ingresos" as const,
    titulo: "Ganar y gestionar ingresos",
    resumen:
      "Temas para entender tu sueldo, ordenar ingresos y saber qué hacer si tu situación laboral cambia.",
  },
  {
    id: "prevision" as const,
    titulo: "Previsión obligatoria",
    resumen:
      "Temas para entender cotizaciones, fondos y decisiones que afectan tu pensión futura.",
  },
  {
    id: "ahorro-inversion" as const,
    titulo: "Ahorro voluntario e inversión",
    resumen:
      "Temas para elegir instrumentos, controlar costos y ajustar el riesgo a tus objetivos.",
  },
  {
    id: "impuestos" as const,
    titulo: "Impuestos personales",
    resumen:
      "Temas para declarar renta, revisar devoluciones y resolver dudas tributarias frecuentes.",
  },
  {
    id: "deuda" as const,
    titulo: "Deuda y crédito",
    resumen:
      "Temas para entender cuánto cuesta un crédito y cómo ordenar tus deudas.",
  },
  {
    id: "bolsillo" as const,
    titulo: "UF, inflación y costo de vida",
    resumen:
      "Temas para entender cómo la inflación, la UF y los reajustes se traducen a pagos reales y contratos cotidianos.",
  },
  {
    id: "otros" as const,
    titulo: "Otras secciones",
    resumen: "Otros temas disponibles para seguir aprendiendo.",
  },
];

const hubsDetectados = Object.keys(import.meta.glob("./*/index.astro"))
  .map(path => path.match(/^\.\/([^/]+)\/index\.astro$/)?.[1])
  .filter((slug): slug is string => Boolean(slug));

const hubSet = new Set(hubsDetectados);
const orderedKnownHubs = GUIDE_HUB_ORDER.filter(slug => hubSet.has(slug)).map(
  slug => ({ slug, ...GUIDE_HUBS[slug] })
);
const fallbackHubs = hubsDetectados
  .filter(
    slug => !GUIDE_HUB_ORDER.includes(slug as (typeof GUIDE_HUB_ORDER)[number])
  )
  .map(slug => ({
    slug,
    nombre: slug
      .split("-")
      .filter(Boolean)
      .map(parte => parte.charAt(0).toUpperCase() + parte.slice(1))
      .join(" "),
    descripcion: "Sección de finanzas personales disponible en esta página.",
    capa: "otros" as const,
  }))
  .sort((a, b) => a.nombre.localeCompare(b.nombre, "es-CL"));

const hubs = [...orderedKnownHubs, ...fallbackHubs];

const capasConHubs = capas
  .map(capa => ({
    ...capa,
    hubs: hubs.filter(hub => hub.capa === capa.id),
  }))
  .filter(capa => capa.hubs.length > 0);
---

<Layout
  title="Guías de Finanzas Personales en Chile | Monedario"
  description="Explora las guías de finanzas personales de Monedario por tema: sueldo, AFP, impuestos, deuda, UF, inflación y ahorro."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <p
        class="mb-2 text-xs font-semibold tracking-widest text-accent uppercase"
      >
        Explora por tema
      </p>
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Guías de Finanzas Personales en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Esta página reúne todas las secciones de Monedario en una sola vista.
        Úsala para encontrar el tema que necesitas y pasar de una duda a otra
        sin perderte.
      </p>
    </section>

    {
      capasConHubs.map(capa => (
        <section class="border-b border-border py-8 last:border-b-0">
          <h2 class="mb-2 text-2xl font-bold">{capa.titulo}</h2>
          <p class="mb-5 max-w-3xl text-secondary">{capa.resumen}</p>

          <ul class="grid gap-4 sm:grid-cols-2">
            {capa.hubs.map(hub => (
              <li class="rounded-xl border border-border p-5">
                <p class="mb-2 inline-flex rounded-full border border-accent/30 bg-accent/5 px-2 py-1 text-xs font-semibold tracking-wide text-accent uppercase">
                  Sección
                </p>
                <h3 class="mb-2 text-lg font-semibold">{hub.nombre}</h3>
                <p class="mb-3 text-sm text-secondary">{hub.descripcion}</p>
                <a
                  href={getPath(`/guias/${hub.slug}/`)}
                  class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
                >
                  Ir a la sección
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </main>

  <Footer />
</Layout>
