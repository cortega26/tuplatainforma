---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ContextLinkSection from "@/components/ContextLinkSection.astro";
import { getPath } from "@/utils/getPath";
import {
  sueldoClusterHubPrimaryCards,
  sueldoClusterHubSupportCards,
} from "@/config/sueldoClusterLinks";

const adjacentRoutes = [
  {
    title: "Contingencias de empleo e ingresos",
    description:
      "Úsalo cuando el problema ya no es la liquidación mensual sino cesantía, licencia médica o finiquito.",
    href: getPath("/guias/empleo-ingresos/"),
  },
  {
    title: "Pensiones y AFP",
    description:
      "Úsalo cuando la decisión principal pasa a ser cambio de AFP, fondos, APV o planificación previsional.",
    href: getPath("/guias/pensiones-afp/"),
  },
];
---

<Layout
  title="Sueldo Líquido y Remuneraciones en Chile | Monedario"
  description="Guía de entrada para entender sueldo líquido, liquidación, descuentos previsionales, impuesto único y herramientas de cálculo en Chile."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <p
        class="mb-2 text-xs font-semibold tracking-widest text-accent uppercase"
      >
        Guía de entrada
      </p>
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Sueldo líquido y remuneraciones en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Aquí puedes entender cuánto te descuentan, por qué tu sueldo líquido
        cambia y qué leer o calcular según tu duda. Usa esta sección para ir
        directo a la guía, a la calculadora o a la ayuda específica que
        necesites.
      </p>
    </section>

    <section class="border-b border-border py-8">
      <div class="grid gap-4 lg:grid-cols-3">
        <article class="rounded-xl border border-border bg-background p-5">
          <p
            class="text-xs font-semibold tracking-[0.16em] text-accent uppercase"
          >
            Si partes desde una oferta o un bruto
          </p>
          <h2 class="mt-3 text-xl font-semibold">Primero calcula el líquido</h2>
          <p class="mt-2 text-sm leading-relaxed text-secondary">
            Sirve para pasar de bruto e imponible a depósito final sin abrir
            todavía el detalle legal de cada línea.
          </p>
          <a
            href={getPath("/calculadoras/sueldo-liquido/")}
            class="mt-4 inline-flex text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
          >
            Abrir calculadora
          </a>
        </article>
        <article class="rounded-xl border border-border bg-background p-5">
          <p
            class="text-xs font-semibold tracking-[0.16em] text-accent uppercase"
          >
            Si ya tienes el comprobante
          </p>
          <h2 class="mt-3 text-xl font-semibold">Audita la liquidación</h2>
          <p class="mt-2 text-sm leading-relaxed text-secondary">
            Revisa haberes, descuentos, respaldos y errores típicos antes de
            asumir que el cálculo del empleador está bien.
          </p>
          <a
            href={getPath("/posts/liquidacion-de-sueldo/")}
            class="mt-4 inline-flex text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
          >
            Leer guía
          </a>
        </article>
        <article class="rounded-xl border border-border bg-background p-5">
          <p
            class="text-xs font-semibold tracking-[0.16em] text-accent uppercase"
          >
            Si el problema cambió
          </p>
          <h2 class="mt-3 text-xl font-semibold">
            Sal de esta sección a tiempo
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-secondary">
            Empleo e ingresos toma el relevo cuando la duda ya es finiquito,
            cesantía o corte del ingreso; honorarios cuando tu caso no nace en
            una liquidación.
          </p>
          <div class="mt-4 flex flex-wrap gap-3 text-sm font-semibold">
            <a
              href={getPath("/guias/empleo-ingresos/")}
              class="text-accent underline underline-offset-4 hover:opacity-80"
            >
              Ir a empleo e ingresos
            </a>
            <a
              href={getPath("/calculadoras/boleta-honorarios-liquido/")}
              class="text-accent underline underline-offset-4 hover:opacity-80"
            >
              Ver honorarios
            </a>
          </div>
        </article>
      </div>
    </section>

    <ContextLinkSection
      eyebrow="Empieza aquí"
      title="Elige la opción que mejor te ayude"
      description="La decisión correcta depende del trabajo que tienes delante: calcular el depósito, auditar el comprobante, clasificar un descuento o pasar a otra sección porque el problema ya cambió."
      items={sueldoClusterHubPrimaryCards}
    />

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Qué encontrarás en esta sección</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>Diferencia entre sueldo bruto, imponible y sueldo líquido.</li>
        <li>
          Descuentos obligatorios que salen de la remuneración: AFP, salud,
          cesantía e impuesto único.
        </li>
        <li>
          Lectura de la liquidación de sueldo y conexión directa con la
          calculadora para revisar montos.
        </li>
        <li>
          Separación entre descuentos obligatorios, autorizados y prohibidos
          para auditar mejor lo que baja tu líquido.
        </li>
        <li>
          Fronteras claras para no mezclar esta sección con honorarios,
          finiquito o cesantía cuando la duda ya se movió de etapa.
        </li>
      </ul>
    </section>

    <ContextLinkSection
      eyebrow="Aclaraciones útiles"
      title="Conceptos y normas para resolver dudas puntuales"
      description="Usa estas ayudas si necesitas entender un término, confirmar una regla o revisar la base legal de un descuento."
      items={sueldoClusterHubSupportCards}
    />

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">
        Cambia de sección si tu duda es otra
      </h2>
      <div class="grid gap-4 md:grid-cols-2">
        {
          adjacentRoutes.map(route => (
            <article class="rounded-xl border border-border p-5">
              <h3 class="text-lg font-semibold">{route.title}</h3>
              <p class="mt-2 text-sm text-secondary">{route.description}</p>
              <a
                href={route.href}
                class="mt-4 inline-flex text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                Ir a esa sección
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <h2 class="mb-2 text-xl font-bold">
          Última actualización de la sección
        </h2>
        <p class="text-sm text-secondary">
          Actualizado: 2026-03-12. Esta sección se revisa cuando cambian
          porcentajes de descuento, reglas de impuesto único, estructura de la
          liquidación o el puente hacia honorarios, finiquito y cesantía.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
