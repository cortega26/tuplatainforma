---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getPath } from "@/utils/getPath";

const articulosSeccion = [
  {
    titulo:
      "Ahorro e inversión en Chile: instrumentos, costos e impuestos (guía 2026)",
    resumen:
      "Guía general para elegir instrumentos según tu plazo, tu tolerancia al riesgo y sus costos.",
    href: getPath(
      "/posts/ahorro-e-inversion-en-chile-instrumentos-costos-impuestos-2026/"
    ),
  },
  {
    titulo:
      "APV en Chile: beneficio tributario, regímenes A y B, y cuándo conviene",
    resumen:
      "Explica cuándo usar APV para ahorrar con beneficio tributario y cómo compararlo con alternativas más líquidas.",
    href: getPath("/posts/que-es-el-apv/"),
  },
  {
    titulo: "Depósito a plazo: UF vs pesos — qué conviene y cuándo",
    resumen:
      "Comparativa para elegir entre tasa nominal y protección por reajuste según inflación esperada.",
    href: getPath("/posts/deposito-a-plazo-uf-vs-pesos/"),
  },
  {
    titulo: "Fondos mutuos: comisiones, rescate e impuestos (sin letra chica)",
    resumen:
      "Explica costos reales, reglas de rescate y tratamiento tributario básico al rescatar cuotas.",
    href: getPath("/posts/fondos-mutuos-comisiones-rescate-impuestos/"),
  },
  {
    titulo:
      "Cómo invertir en ETFs desde Chile: comisiones, custodia e impuestos",
    resumen:
      "Explica cómo elegir una corredora, revisar costos, custodia e impuestos antes de invertir.",
    href: getPath("/posts/como-invertir-en-etfs-desde-chile/"),
  },
];
---

<Layout
  title="Ahorro e Inversión en Chile | Monedario"
  description="Guías y artículos sobre ahorro e inversión en Chile para elegir qué leer primero según tu objetivo, plazo y nivel de riesgo."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <!-- Removed Topic Authority Layer tag -->
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Ahorro e inversión en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Esta página te ayuda a elegir qué leer primero según tu objetivo, tu
        plazo y el nivel de riesgo que estás dispuesto a asumir. Aquí también
        viven instrumentos de ahorro con beneficio tributario como el APV. Si tu
        duda es AFP obligatoria, fondos previsionales o cambio de
        administradora, te conviene ir a pensiones y AFP.
      </p>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Temas que puedes revisar</h2>
      <ul class="grid gap-4">
        {
          articulosSeccion.map(item => (
            <li class="rounded-xl border border-border p-5">
              <h3 class="mb-2 text-lg font-semibold">{item.titulo}</h3>
              <p class="mb-3 text-sm text-secondary">{item.resumen}</p>
              <a
                href={item.href}
                class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                Leer artículo
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Empieza aquí si...</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <article class="rounded-xl border border-border p-5">
          <h3 class="mb-2 text-lg font-semibold">
            Quieres ahorrar para jubilación bajando impuesto
          </h3>
          <p class="text-sm text-secondary">
            Parte por APV si estás comparando beneficio tributario, regímenes A
            y B o cuándo conviene sobre otras alternativas.
          </p>
          <a
            href={getPath("/posts/que-es-el-apv/")}
            class="mt-3 inline-block text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
          >
            Ir a guía de APV
          </a>
        </article>

        <article class="rounded-xl border border-border p-5">
          <h3 class="mb-2 text-lg font-semibold">
            Eres conservador y priorizas preservar capital
          </h3>
          <p class="text-sm text-secondary">
            Comienza por depósito a plazo UF vs pesos y luego ve si realmente te
            sirve para tu plan.
          </p>
          <a
            href={getPath("/posts/deposito-a-plazo-uf-vs-pesos/")}
            class="mt-3 inline-block text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
          >
            Leer comparativa DAP
          </a>
        </article>

        <article class="rounded-xl border border-border p-5">
          <h3 class="mb-2 text-lg font-semibold">
            Eres balanceado y quieres diversificar sin complejidad extrema
          </h3>
          <p class="text-sm text-secondary">
            Empieza por la guía general y sigue con fondos mutuos para entender
            costos y liquidez real.
          </p>
          <a
            href={getPath("/posts/fondos-mutuos-comisiones-rescate-impuestos/")}
            class="mt-3 inline-block text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
          >
            Ver guía de fondos mutuos
          </a>
        </article>

        <article class="rounded-xl border border-border p-5">
          <h3 class="mb-2 text-lg font-semibold">
            Eres agresivo y buscas exposición a mercado global
          </h3>
          <p class="text-sm text-secondary">
            Revisa ETFs desde Chile si quieres entender costos, custodia y qué
            debes mirar antes de invertir.
          </p>
          <a
            href={getPath("/posts/como-invertir-en-etfs-desde-chile/")}
            class="mt-3 inline-block text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
          >
            Ir a guía de ETFs
          </a>
        </article>

        <article class="rounded-xl border border-border p-5">
          <h3 class="mb-2 text-lg font-semibold">
            Quieres un plan integral antes de mover plata
          </h3>
          <p class="text-sm text-secondary">
            Empieza por la guía general y después revisa el instrumento que más
            se ajuste a tu caso.
          </p>
          <a
            href={getPath(
              "/posts/ahorro-e-inversion-en-chile-instrumentos-costos-impuestos-2026/"
            )}
            class="mt-3 inline-block text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
          >
            Leer guía general de ahorro e inversión
          </a>
        </article>
      </div>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Errores comunes de la sección</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>Comparar solo rentabilidad y no costo total neto.</li>
        <li>
          Usar instrumentos de alta volatilidad para metas de corto plazo.
        </li>
        <li>Invertir sin revisar reglas de rescate, vencimiento o custodia.</li>
        <li>
          Asumir que todos los intermediarios tienen el mismo nivel de
          supervisión aplicable.
        </li>
        <li>Postergar revisión tributaria hasta el cierre del año.</li>
        <li>
          Confundir una decisión de ahorro con beneficio tributario con una duda
          operativa sobre AFP obligatoria.
        </li>
      </ul>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <h2 class="mb-2 text-xl font-bold">
          Última actualización de la sección
        </h2>
        <p class="text-sm text-secondary">
          Actualizado: 2026-03-09. Se actualiza cuando cambian reglas
          regulatorias CMF, instrucciones tributarias SII o cambios importantes
          en estos instrumentos.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
