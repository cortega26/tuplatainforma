---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getPath } from "@/utils/getPath";

const articulosSeccion = [
  {
    titulo: "¿Puedo cambiarme de AFP? Cómo hacerlo y qué considerar en 2026",
    resumen:
      "Explica qué mirar antes de cambiarte, cómo hacerlo y qué errores evitar.",
    href: getPath("/posts/como-cambiarse-de-afp/"),
  },
  {
    titulo:
      "¿Cuánto descuenta la AFP de tu sueldo y para qué sirve ese dinero?",
    resumen:
      "Desglosa cotización obligatoria, comisión y su impacto real en el líquido mensual.",
    href: getPath("/posts/cuanto-descuenta-la-afp-de-tu-sueldo/"),
  },
  {
    titulo: "Fondos AFP A, B, C, D y E: diferencias, riesgo y cuál te conviene",
    resumen:
      "Explica las diferencias entre fondos y cuál puede calzar mejor con tu edad y tolerancia al riesgo.",
    href: getPath("/posts/fondos-afp-a-b-c-d-e/"),
  },
  {
    titulo: "¿Qué es la Cuenta 2 de la AFP y cuándo conviene usarla?",
    resumen:
      "Explica para qué sirve la Cuenta 2, cómo retirar y en qué se diferencia del APV.",
    href: getPath("/posts/que-es-la-cuenta-2-afp/"),
  },
  {
    titulo: "¿Qué es el APV y cómo funciona el beneficio tributario en Chile?",
    resumen:
      "Explica cómo funciona el beneficio tributario del APV y cuándo puede convenirte.",
    href: getPath("/posts/que-es-el-apv/"),
  },
];
---

<Layout
  title="Pensiones y AFP en Chile | Monedario"
  description="Guías y artículos sobre pensiones y AFP en Chile para elegir qué leer primero según tu duda previsional."
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-8">
      <!-- Removed Topic Authority Layer tag -->
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Pensiones y AFP en Chile
      </h1>
      <p class="max-w-3xl text-secondary">
        Esta página te ayuda a elegir qué leer primero si estás revisando tu
        AFP, tus fondos o tus opciones de ahorro previsional. Úsala para ir
        directo al tema que te importa hoy.
      </p>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Temas que puedes revisar</h2>
      <ul class="grid gap-4">
        {
          articulosSeccion.map(item => (
            <li class="rounded-xl border border-border p-5">
              <h3 class="mb-2 text-lg font-semibold">{item.titulo}</h3>
              <p class="mb-3 text-sm text-secondary">{item.resumen}</p>
              <a
                href={item.href}
                class="text-sm font-semibold text-accent underline underline-offset-4 hover:opacity-80"
              >
                Leer artículo
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Empieza aquí si...</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          Estás evaluando cambio de AFP: parte por{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/como-cambiarse-de-afp/")}
          >
            la guía de cambio de AFP
          </a>{" "}
          y luego revisa fondos A-E.
        </li>
        <li>
          Quieres bajar impuesto mientras ahorras para jubilación: parte por{
            " "
          }
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/que-es-el-apv/")}
          >
            la guía de APV
          </a>{" "}
          y luego revisa Cuenta 2 o cambio de AFP según tu objetivo.
        </li>
        <li>
          Buscas ahorro previsional con mayor flexibilidad: revisa{" "}
          <a
            class="text-accent underline underline-offset-4 hover:opacity-80"
            href={getPath("/posts/que-es-la-cuenta-2-afp/")}
          >
            Cuenta 2 AFP
          </a>{" "}
          después de entender tu perfil de fondos.
        </li>
      </ul>
    </section>

    <section class="border-b border-border py-8">
      <h2 class="mb-4 text-2xl font-bold">Errores comunes</h2>
      <ul class="list-disc space-y-2 pl-6 text-secondary">
        <li>
          Elegir AFP o fondo solo por una foto de rentabilidad de corto plazo.
        </li>
        <li>Confundir comisión baja con mejor resultado previsional total.</li>
        <li>
          No revisar impacto de decisiones previsionales en el sueldo líquido
          mensual.
        </li>
        <li>
          Seguir aquí cuando tu duda real es la liquidación mensual. En ese
          caso, te conviene ir a sueldo y remuneraciones.
        </li>
      </ul>
    </section>

    <section class="py-8">
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <h2 class="mb-2 text-xl font-bold">
          Última actualización de la sección
        </h2>
        <p class="text-sm text-secondary">
          Actualizado: 2026-03-02. Esta sección se revisa cuando cambian
          comisiones AFP, reglas de traspaso, reglas de fondos o normativa
          previsional obligatoria.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
