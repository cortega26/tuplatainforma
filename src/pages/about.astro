---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
---

<Layout title={`¿Quiénes somos? | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section class="border-b border-border py-10">
      <p
        class="mb-3 text-xs font-semibold tracking-widest text-accent uppercase"
      >
        Sobre nosotros
      </p>
      <h1 class="mb-4 text-3xl font-bold sm:text-4xl">
        Cuando entiendes tu plata,<br />tomas mejores decisiones.
      </h1>
      <p class="max-w-2xl text-base leading-relaxed text-secondary">
        <strong class="text-foreground">Tu Plata Informa</strong> es un proyecto
        de educación financiera dedicado a explicar el sistema financiero chileno
        de forma clara, rigurosa y basada en fuentes oficiales. Su misión es
        ayudar a las personas a entender decisiones financieras complejas
        —ahorro, inversión, impuestos, crédito o pensiones— sin conflictos de
        interés.
      </p>
    </section>

    <!-- POR QUÉ EXISTE -->
    <section class="border-b border-border py-10">
      <h2 class="mb-4 text-2xl font-bold">¿Por qué existe este sitio?</h2>
      <p class="max-w-2xl text-base leading-relaxed text-secondary">
        Porque la mayoría de la información financiera disponible en internet
        está escrita para economistas, no para personas normales. Los trámites
        de la AFP, el beneficio tributario del APV, los tramos del impuesto de
        segunda categoría — todo eso afecta directamente tu bolsillo, pero nadie
        te lo explica en términos simples.
      </p>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-secondary">
        TuPlataInforma nació para cambiar eso.
      </p>
    </section>

    <!-- QUÉ ENCONTRARÁS -->
    <section class="border-b border-border py-10">
      <h2 class="mb-6 text-2xl font-bold">¿Qué encontrarás aquí?</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-border p-5">
          <p class="mb-1 text-lg font-semibold">📋 Guías claras</p>
          <p class="text-sm text-secondary">
            AFP, APV, impuestos, inversiones y créditos explicados para la
            realidad chilena.
          </p>
        </div>
        <div class="rounded-xl border border-border p-5">
          <p class="mb-1 text-lg font-semibold">🧮 Calculadoras prácticas</p>
          <p class="text-sm text-secondary">
            Herramientas para que puedas hacer tus propios números sin depender
            de nadie.
          </p>
        </div>
        <div class="rounded-xl border border-border p-5">
          <p class="mb-1 text-lg font-semibold">🔄 Contenido actualizado</p>
          <p class="text-sm text-secondary">
            Pensado para la realidad chilena y actualizado cuando cambian las
            leyes y tasas.
          </p>
        </div>
        <div class="rounded-xl border border-border p-5">
          <p class="mb-1 text-lg font-semibold">🔓 Sin letra chica</p>
          <p class="text-sm text-secondary">
            Todo gratis, sin registro, sin spam. Sin conflictos de interés.
          </p>
        </div>
      </div>
    </section>

    <!-- QUIÉN LO ESCRIBE -->
    <section class="border-b border-border py-10">
      <h2 class="mb-6 text-2xl font-bold">¿Quién lo escribe?</h2>
      <div class="flex flex-col gap-4 rounded-xl border border-border p-5 sm:flex-row sm:items-start">
        <div
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-accent/30 bg-accent/10 text-sm font-bold text-accent"
          aria-hidden="true"
        >
          CO
        </div>
        <div>
          <p class="font-semibold text-foreground">
            <a
              href="/autor/"
              class="hover:text-accent hover:underline underline-offset-4 transition-colors"
            >
              Carlos Ortega González
            </a>
          </p>
          <p class="mt-1 text-sm text-secondary">
            Abogado, analista de datos y desarrollador especializado en educación
            financiera práctica. Investiga normativa financiera chilena, compara
            instrumentos de ahorro e inversión y desarrolla herramientas claras
            y basadas en evidencia.
          </p>
          <div class="mt-2 flex flex-wrap gap-3 text-xs">
            <a
              href="/autor/"
              class="text-accent hover:underline underline-offset-4"
            >
              Ver perfil completo →
            </a>
            <a
              href="https://www.linkedin.com/in/cortega26/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-secondary hover:text-accent transition-colors"
            >
              LinkedIn ↗
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- AVISO LEGAL -->
    <section class="mb-10 py-10">
      <div class="rounded-xl border border-accent/20 bg-accent/5 p-6">
        <h2 class="mb-3 text-lg font-bold">⚠️ Aviso importante</h2>
        <p class="text-sm leading-relaxed text-secondary">
          La información publicada en TuPlataInforma tiene <strong
            class="text-foreground">carácter exclusivamente educativo</strong
          > y no constituye asesoría financiera, tributaria ni legal. Siempre consulta
          con un profesional calificado antes de tomar decisiones importantes sobre
          tu dinero.
        </p>
        <p class="mt-3 text-sm text-secondary">
          El contenido se elabora a partir de normativa oficial y fuentes públicas, y
          se actualiza periódicamente. El sitio mantiene
          <strong class="text-foreground">independencia editorial</strong>: no está
          condicionado por comisiones, publicidad financiera ni acuerdos con
          instituciones.
        </p>
        <p class="mt-3 text-sm text-secondary">
          Para información oficial consulta la
          <a
            href="https://www.spensiones.cl"
            target="_blank"
            class="text-accent underline underline-offset-4 hover:opacity-80"
            >Superintendencia de Pensiones</a
          >, la <a
            href="https://www.cmfchile.cl"
            target="_blank"
            class="text-accent underline underline-offset-4 hover:opacity-80"
            >CMF</a
          > y el
          <a
            href="https://www.sii.cl"
            target="_blank"
            class="text-accent underline underline-offset-4 hover:opacity-80"
            >SII</a
          >.
        </p>
      </div>
      <p class="mt-6 text-sm text-muted">
        ¿Tienes alguna sugerencia o encontraste un error?
        <a
          href="https://github.com/cortega26/tuplatainforma"
          target="_blank"
          class="text-accent underline underline-offset-4 hover:opacity-80"
          >Escríbenos en GitHub</a
        >.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
