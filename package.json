{
  "name": "tuplatainforma",
  "type": "module",
  "version": "5.5.1",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run check:images && pnpm run check:frontmatter && astro check && astro build && pnpm run check:toc-i18n && pnpm run check:editorial-guard && pagefind --site dist && cp -r dist/pagefind public/ && pnpm run check:urls",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "check": "pnpm run check:context && pnpm run check:docs && pnpm run check:images && pnpm run check:frontmatter && pnpm run check:links && pnpm run check:editorial && pnpm run check:no-postid-urls && astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:context": "node scripts/check-context.mjs",
    "check:docs": "node scripts/check-docs-structure.mjs",
    "check:images": "node scripts/check-images.mjs",
    "check:frontmatter": "node scripts/check-frontmatter.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:urls": "node scripts/check-urls.mjs",
    "check:editorial-structure": "node scripts/check-editorial-structure.mjs",
    "check:dialect": "node scripts/check-dialect.mjs",
    "check:editorial-artifacts": "node scripts/check-editorial-artifacts.mjs",
    "check:editorial": "pnpm run check:editorial-structure && pnpm run check:dialect && pnpm run check:editorial-artifacts",
    "check:no-postid-urls": "node scripts/check-no-postid-urls.mjs",
    "routes:snapshot": "node scripts/snapshot-routes.mjs",
    "routes:compare": "node scripts/compare-routes.mjs docs/reports/routes_snapshot_before.json docs/reports/routes_snapshot_after.json",
    "check:routes": "node scripts/snapshot-routes.mjs --out docs/reports/routes_snapshot_after.json && pnpm run routes:compare",
    "rss:snapshot": "node scripts/rss-to-json.mjs --in dist/rss.xml --out docs/reports/rss_snapshot.json",
    "rss:compare": "node scripts/compare-rss.mjs docs/reports/rss_snapshot.json docs/reports/rss_snapshot_after.json",
    "check:rss": "node scripts/rss-to-json.mjs --in dist/rss.xml --out docs/reports/rss_snapshot_after.json && pnpm run rss:compare",
    "check:boundaries": "node scripts/check-domain-boundaries.mjs",
    "check:toc-i18n": "node scripts/check-toc-i18n.mjs",
    "check:editorial-guard": "node scripts/check-editorial-guard.mjs",
    "economic:snapshot:refresh": "node scripts/refresh-economic-snapshot.mjs",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "check:urls:ci": "URLCHECK_MODE=ci node scripts/check-urls.mjs",
    "check:urls:canary": "node scripts/check-urls.mjs --canary",
    "check:urls:external:audit": "URLCHECK_MODE=ci node scripts/check-urls.mjs --external-audit",
    "check:urls:baseline:update": "node scripts/check-urls.mjs --update-baseline --allow-baseline-update"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.18.0",
    "dayjs": "^1.11.19",
    "lodash.kebabcase": "^4.1.1",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.19.2",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@pagefind/default-ui": "^1.4.0",
    "@shikijs/transformers": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.5.0",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "linkinator": "^7.6.1",
    "pagefind": "^1.4.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sitemap": "^9.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.18"
  }
}
